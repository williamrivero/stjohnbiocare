---
import { site } from '../data/site';
import { openBranches } from '../data/branches';
const year = 2026;
---
<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <div>
        <div class="brand" style="margin-bottom:14px">
          <img src="/logo.png" alt="St. John Biocare logo" width="40" height="40" />
          <strong style="font-family:var(--font-head);color:#fff;font-size:1.15rem">St. John Biocare</strong>
        </div>
        <p style="max-width:34ch;color:#cfe6d6">
          A registered foundation providing warm, honest, patient-first hemodialysis
          and diagnostics across Metro Manila since 2011.
        </p>
        <p class="footer__dedication">“Dedicated to all of us.”</p>
      </div>

      <div>
        <h4>Explore</h4>
        <ul style="list-style:none;padding:0;margin:0;line-height:2">
          <li><a href="/about">About Us</a></li>
          <li><a href="/services">Services</a></li>
          <li><a href="/centers">Our Centers</a></li>
          <li><a href="/kidney-health">Kidney Health Hub</a></li>
          <li><a href="/training-academy">Training Academy</a></li>
          <li><a href="/careers">Careers</a></li>
        </ul>
      </div>

      <div>
        <h4>Our Centers</h4>
        <ul style="list-style:none;padding:0;margin:0;line-height:2">
          {openBranches.map((b) => (
            <li><a href={`/centers/${b.slug}`}>{b.name}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h4>Talk to us</h4>
        <p style="color:#cfe6d6;margin-bottom:.4rem">
          <a href={site.phoneHref}>{site.phone}</a>
        </p>
        <p style="color:#cfe6d6;margin-bottom:.4rem">
          <a href={`mailto:${site.email}`}>{site.email}</a>
        </p>
        <a href="/new-patients#request" class="btn btn--light" style="margin-top:10px">Request an appointment</a>
        <p style="color:#cfe6d6;font-size:.82rem;margin-top:14px">
          Open Mon–Sat from 5:30&nbsp;AM. This site is not for emergencies —
          for urgent concerns, call your nearest center or the hospital ER.
        </p>
      </div>
    </div>

    <div class="footer__bottom">
      <span>© {year} {site.legalName}. All rights reserved.</span>
      <span style="display:flex;gap:16px;flex-wrap:wrap">
        <a href="/legal/privacy">Privacy (Data Privacy Act)</a>
        <a href="/legal/patient-rights">Patient Rights</a>
        <a href="/legal/terms">Terms</a>
      </span>
    </div>
  </div>
</footer>
