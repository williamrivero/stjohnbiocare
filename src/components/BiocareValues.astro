---
import { site } from '../data/site';
---
<div class="biocare">
  {site.biocare.map((v) => (
    <div class="biocare__item">
      <div class="biocare__letter" aria-hidden="true">{v.letter}</div>
      <div>
        <h3 class="biocare__title">{v.title}</h3>
        <p class="biocare__text">{v.text}</p>
      </div>
    </div>
  ))}
</div>

<style>
  .biocare { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
  @media (max-width: 720px) { .biocare { grid-template-columns: 1fr; } }
  .biocare__item {
    display: flex; gap: 16px; align-items: flex-start;
    background: var(--white); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 20px 22px;
  }
  .biocare__letter {
    flex: 0 0 auto; width: 52px; height: 52px; border-radius: 14px;
    display: grid; place-items: center;
    font-family: var(--font-head); font-weight: 700; font-size: 1.7rem; color: #fff;
    background: linear-gradient(140deg, var(--life), var(--forest));
  }
  .biocare__title { margin: 2px 0 .2rem; font-size: 1.12rem; }
  .biocare__text { margin: 0; color: var(--ink-soft); font-size: .98rem; }
</style>
