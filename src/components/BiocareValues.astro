---
import { site } from '../data/site';
---
<div class="biocare">
  {site.biocare.map((v, i) => (
    <div class="biocare__item" style={`--i:${i}`}>
      <div class="biocare__letter" aria-hidden="true">{v.letter}</div>
      <div>
        <h3 class="biocare__title">{v.title}</h3>
        <p class="biocare__text">{v.text}</p>
      </div>
    </div>
  ))}
</div>

<style>
  /* Single descending column so the B-I-O-C-A-R-E letters read vertically. */
  .biocare { display: grid; grid-template-columns: 1fr; gap: 14px; max-width: 660px; margin-inline: auto; }
  .biocare__item {
    display: flex; gap: 16px; align-items: flex-start;
    background: var(--white); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 20px 22px;
  }
  /* staggered stacking reveal — enabled by JS (cards visible without JS).
     Cards deal in one by one in DOM order: B → I → O → C → A → R → E */
  .biocare.js-anim .biocare__item {
    opacity: 0;
    transform: translateY(26px) scale(.97);
    transition: opacity .5s ease, transform .55s cubic-bezier(.2,.75,.2,1);
    transition-delay: calc(var(--i, 0) * 95ms);
    will-change: opacity, transform;
  }
  .biocare.js-anim.is-in .biocare__item { opacity: 1; transform: none; }
  @media (prefers-reduced-motion: reduce) {
    .biocare.js-anim .biocare__item { opacity: 1; transform: none; transition: none; }
  }
  .biocare__letter {
    flex: 0 0 auto; width: 52px; height: 52px; border-radius: 14px;
    display: grid; place-items: center;
    font-family: var(--font-head); font-weight: 700; font-size: 1.7rem; color: #fff;
    background: linear-gradient(140deg, var(--life), var(--forest));
  }
  .biocare__title { margin: 2px 0 .2rem; font-size: 1.12rem; }
  .biocare__text { margin: 0; color: var(--ink-soft); font-size: .98rem; }
</style>

<script>
  // Reveal each BIOCARE card in sequence when the block scrolls into view.
  const reveal = () => {
    const blocks = document.querySelectorAll('.biocare');
    blocks.forEach((b) => b.classList.add('js-anim'));
    if (!('IntersectionObserver' in window)) {
      blocks.forEach((b) => b.classList.add('is-in'));
      return;
    }
    const obs = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (e.isIntersecting) { e.target.classList.add('is-in'); obs.unobserve(e.target); }
      }
    }, { threshold: 0.2 });
    blocks.forEach((b) => obs.observe(b));
  };
  reveal();
  document.addEventListener('astro:page-load', reveal);
</script>
