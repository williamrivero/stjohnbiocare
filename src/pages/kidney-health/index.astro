---
import BaseLayout from '../../layouts/BaseLayout.astro';
const articles = [
  { href: '/kidney-health/understanding-kidney-disease', title: 'Understanding kidney disease & ESRD', text: 'What the kidneys do, what goes wrong, and what dialysis replaces.' },
  { href: '/kidney-health/starting-dialysis', title: 'Starting dialysis: what to expect', text: 'Your first sessions, step by step — with the fear taken out.' },
  { href: '/kidney-health/philhealth-cost', title: 'PhilHealth & the cost of dialysis', text: 'The most-searched, least-answered question — answered honestly.' },
];
---
<BaseLayout title="Kidney Health Hub" description="Plain-language, nephrologist-reviewed guides to kidney disease, dialysis, and living well — for patients and families.">
  <section class="section" style="background:linear-gradient(180deg,var(--mist),var(--cream));padding-block:48px">
    <div class="container" style="max-width:780px">
      <p class="eyebrow">Kidney Health Hub</p>
      <h1>Understand your kidneys, in plain Filipino-English.</h1>
      <p class="lead">Warm, accurate guides written for worried patients and the families caring for them.</p>
    </div>
  </section>
  <section class="section">
    <div class="container grid grid--3">
      {articles.map((a) => (
        <a class="card" href={a.href} style="text-decoration:none;color:inherit">
          <h3>{a.title}</h3>
          <p>{a.text}</p>
          <span class="card__link">Read</span>
        </a>
      ))}
    </div>
    <p class="container muted" style="margin-top:20px;font-size:.9rem">More guides — living well on dialysis, diet, work and travel, and FAQs — are on the way.</p>
  </section>
</BaseLayout>
