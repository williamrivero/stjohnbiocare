---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';

const categories = [
  {
    name: 'Understanding your kidneys',
    articles: [
      { href: '/kidney-health/understanding-kidney-disease', title: 'Understanding kidney disease & ESRD', text: 'What the kidneys do, what goes wrong, and what dialysis replaces.', img: '/images/kidney-health/understanding-kidney-disease.webp' },
    ],
  },
  {
    name: 'Getting started',
    articles: [
      { href: '/kidney-health/starting-dialysis', title: 'Starting dialysis: what to expect', text: "What to bring, who you'll meet, and what actually happens.", img: '/images/kidney-health/starting-dialysis.webp' },
      { href: '/kidney-health/transfer-of-care', title: 'Transferring your care', text: 'Change centers safely, without missing a single session.', img: '/images/kidney-health/transfer-of-care.webp' },
    ],
  },
  {
    name: 'Living well on dialysis',
    articles: [
      { href: '/kidney-health/living-well-on-dialysis', title: 'Living well on dialysis', text: 'How dialysis works — and how to keep living your life.', img: '/images/kidney-health/living-well-on-dialysis.webp' },
      { href: '/kidney-health/eating-well-on-dialysis', title: 'Eating well on dialysis', text: 'Salt, potassium and phosphorus — the three that matter most.', img: '/images/kidney-health/eating-well-on-dialysis.webp' },
      { href: '/kidney-health/fluid-and-weight', title: 'Fluid & weight between sessions', text: 'Why fluid builds up, and the habits that protect your heart.', img: '/images/kidney-health/fluid-and-weight.webp' },
      { href: '/kidney-health/dialysis-access-care', title: 'Caring for your dialysis access', text: 'Protect your fistula — and know the warning signs.', img: '/images/kidney-health/dialysis-access-care.webp' },
      { href: '/kidney-health/travelling-on-dialysis', title: 'Travelling on dialysis', text: 'Travel is possible — with the right planning.', img: '/images/kidney-health/travelling-on-dialysis.webp' },
    ],
  },
  {
    name: 'For families & caregivers',
    articles: [
      { href: '/kidney-health/caregivers-guide', title: 'A guide for caregivers', text: 'How to help, what to watch for, and caring for yourself too.', img: '/images/kidney-health/caregivers-guide.webp' },
      { href: '/kidney-health/faq', title: 'Frequently asked questions', text: 'The things patients and families ask us most.', img: '/images/kidney-health/faq.webp' },
    ],
  },
  {
    name: 'Cost & coverage',
    articles: [
      { href: '/kidney-health/philhealth-cost', title: 'PhilHealth & the cost of dialysis', text: 'The real numbers, what PhilHealth covers, and what to expect at a private center.', img: '/images/kidney-health/philhealth-cost.webp' },
    ],
  },
];
---
<BaseLayout title="Kidney Health Hub" description="Plain-language, nephrologist-reviewed guides to kidney disease, dialysis, living well, and cost — for patients and families." image="/images/og/og-kidney-health.jpg">
  <PageHero
    image="/images/heroes/kidney-health-hero.webp"
    alt="A St. John Biocare nephrologist explaining kidney health to an older patient and their family using a kidney model"
    eyebrow="Kidney Health Hub"
    title="Understand your kidneys, in plain Filipino-English."
    subtitle="Warm, accurate guides written for worried patients and the families caring for them — reviewed by a nephrologist."
  />

  <section class="section">
    <div class="container">
      {categories.map((cat) => (
        <div style="margin-bottom:40px">
          <h2 style="font-size:1.4rem;margin-bottom:16px">{cat.name}</h2>
          <div class="grid grid--3">
            {cat.articles.map((a) => (
              <a class="card kh-card" href={a.href} style="text-decoration:none;color:inherit">
                <img class="kh-thumb" src={a.img} alt={a.title} loading="lazy" width="900" height="600" />
                <div class="kh-body">
                  <h3>{a.title}</h3>
                  <p>{a.text}</p>
                  <span class="card__link">Read</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      ))}
      <div style="margin-bottom:40px">
        <h2 style="font-size:1.4rem;margin-bottom:16px">Printable food guides (PDF)</h2>
        <div class="grid grid--3">
          <a class="card kh-dl" href="/downloads/wgmr-phosphorus-food-guide.pdf" download>
            <div class="kh-body">
              <span class="kh-dl-tag">PDF · Printable</span>
              <h3>Phosphorus Food Guide</h3>
              <p>A Filipino-food phosphorus heat-map, the phosphate binders available here and how to take them,
              label-reading tips, and cooking tricks that lower phosphorus.</p>
              <span class="card__link">⬇ Download</span>
            </div>
          </a>
          <a class="card kh-dl" href="/downloads/wgmr-potassium-food-guide.pdf" download>
            <div class="kh-body">
              <span class="kh-dl-tag">PDF · Printable</span>
              <h3>Potassium Food Guide</h3>
              <p>High, moderate and low-potassium Filipino foods by CKD stage, the warning signs of hyperkalemia,
              and safe cooking (leaching) tips.</p>
              <span class="card__link">⬇ Download</span>
            </div>
          </a>
          <a class="card kh-dl" href="/downloads/wgmr-sodium-food-guide.pdf" download>
            <div class="kh-body">
              <span class="kh-dl-tag">PDF · Printable</span>
              <h3>Sodium &amp; Salt Guide</h3>
              <p>Daily sodium targets by CKD stage, a high/moderate/low-sodium Filipino-food table, and a
              7-day one-change-a-day salt reduction plan.</p>
              <span class="card__link">⬇ Download</span>
            </div>
          </a>
        </div>
      </div>
      <p class="container muted" style="margin-top:8px;font-size:.9rem">
        Guides adapted with permission from
        <a href="https://renalcarematters.com">renalcarematters.com</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .kh-card { padding: 0; overflow: hidden; display: flex; flex-direction: column; }
  .kh-thumb { width: 100%; aspect-ratio: 3 / 2; object-fit: cover; display: block; background: var(--mist); }
  .kh-body { padding: 20px 22px 22px; }
  .kh-body h3 { margin: 0 0 .35rem; }
  .kh-body p { margin: 0 0 .7rem; }
  .kh-dl { border-top: 3px solid var(--life); }
  .kh-dl-tag { display: inline-block; font-size: .7rem; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; color: var(--forest); background: var(--mist); padding: 3px 9px; border-radius: 999px; margin-bottom: 10px; }
</style>
