---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
---
<BaseLayout title="Training Academy" description="The St. John Biocare Hemodialysis Nurses Training Program — building renal nursing skill from the ground up." image="/images/photos/dsc_0026.webp">
  <PageHero
    image="/images/photos/dsc_0026.webp"
    alt="A St. John Biocare senior nurse reviewing a patient chart with two trainee nurses"
    eyebrow="Training Academy"
    title="We train the nurses others hire."
    subtitle="The Hemodialysis Nurses Training Program builds competent, confident renal nurses — theory and supervised clinical practice, led by our nephrology and nursing leadership."
  />


  <section class="section">
    <div class="container grid grid--2" style="max-width:900px">
      <div class="card"><h3>Who it's for</h3><p>New graduates and registered nurses moving into renal and dialysis care.</p></div>
      <div class="card"><h3>What you'll learn</h3><p>Machine operation, water treatment, infection control, patient assessment — plus supervised clinical hours.</p></div>
      <div class="card"><h3>Duration &amp; schedule</h3><p class="muted">To be confirmed.</p></div>
      <div class="card"><h3>What you earn</h3><p class="muted">Certification / CPD details to be confirmed.</p></div>
    </div>
    <div class="container center" style="margin-top:28px">
      <a href="/careers" class="btn btn--primary">Train here, then join us →</a>
      <p class="muted" style="margin-top:14px;font-size:.9rem">Curriculum, fees/scholarships, trainers and an application form to be added.</p>
    </div>
  </section>
</BaseLayout>
