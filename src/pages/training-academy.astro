---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';

const highlights = [
  { t: '6-week program', d: 'A focused, comprehensive course from the ground up.' },
  { t: 'Didactic + hands-on', d: 'Classroom lectures plus supervised clinical exposure.' },
  { t: 'Expert instruction', d: 'Led by our senior renal nurses and key clinical leads.' },
  { t: 'Certificate of Training', d: 'Earn a certificate that strengthens your credentials.' },
];

const requirements = [
  'Updated résumé',
  'Photocopy of PRC ID',
  'Updated Hepatitis profile result (Anti-HCV, Anti-HBs and HBsAg)',
  'Vaccination ID / passport (COVID-19 vaccination records)',
];

const faqs = [
  { q: 'Who can join the program?', a: 'The program is open to all Registered Nurses (RNs). You do not need prior dialysis experience — we build your hemodialysis skills from the ground up.' },
  { q: 'When is the next batch, and what is the schedule?', a: 'Our next batch runs July 20 – August 28, 2026, Monday to Friday, 8:00 AM to 4:00 PM, at our Quezon Avenue main branch. It combines on-site lectures with supervised, hands-on clinical exposure.' },
  { q: 'How much is the training fee, and how do I pay?', a: 'The fee is ₱14,000, inclusive of the HD in-house manual and consumables (gloves and N95 masks). You may pay in cash or by installment — 50% (₱7,000) down on or before the start, and the balance during the training — via bank transfer to our PBCOM account or at the cashier.' },
  { q: 'What will I learn?', a: 'Patient care and assessment, basic hemodialysis skills, vascular-access safeguarding, and infection-control protocols — through both classroom lectures and supervised clinical practice.' },
  { q: 'Do I receive a certificate?', a: 'Yes. On successful completion you earn a Certificate of Training that strengthens your professional credentials.' },
  { q: 'What are the requirements to enroll?', a: 'An updated résumé, a photocopy of your PRC ID, an updated Hepatitis profile (Anti-HCV, Anti-HBs and HBsAg), and your vaccination records (COVID-19). Please bring the originals on your first day.' },
  { q: 'Will this help me get hired?', a: 'Many of our graduates go on to join the St. John Biocare family, and the Certificate of Training strengthens your credentials wherever you choose to apply.' },
  { q: 'How do I enroll?', a: 'Register through the form below, call +63 (2) 8375 1575 or +63 (2) 8921 8921, or message us on Facebook at facebook.com/sjbdc.' },
];
---
<BaseLayout title="Training Academy" description="The St. John Biocare Hemodialysis Nurse Training Program for Registered Nurses — 6 weeks, didactic + hands-on, with a Certificate of Training. Next batch: July 20 – August 28, 2026." image="/images/og/og-training.jpg">
  <PageHero
    image="/images/photos/dsc_0026.webp"
    alt="A St. John Biocare senior nurse reviewing a patient chart with two trainee nurses"
    eyebrow="Training Academy"
    title="We train the nurses others hire."
    subtitle="A high-quality Hemodialysis (HD) Training Program that develops your skills and molds you into a competent, proactive HD nurse."
  />

  <section class="section">
    <div class="container" style="max-width:900px">
      <p class="eyebrow">Hemodialysis Nurse Training Program</p>
      <h2>Come and be part of our team.</h2>
      <p class="lead">We invite all <strong>Registered Nurses (RNs)</strong> to join our growing team. St. John
      Biocare &amp; Dialysis Center offers a hands-on HD training course led by experienced renal nurses.</p>

      <div class="grid grid--2" style="margin-top:22px">
        {highlights.map((h) => (
          <div class="card"><h3 style="font-size:1.15rem">{h.t}</h3><p style="margin:0">{h.d}</p></div>
        ))}
      </div>
    </div>
  </section>

  <section class="section" style="padding-block:0">
    <div class="container" style="max-width:920px">
      <figure style="margin:0">
        <picture>
          <source srcset="/images/og/og-training.webp" type="image/webp" />
          <img src="/images/og/og-training.jpg" width="1200" height="630" loading="lazy"
               alt="St. John Biocare Hemodialysis Nurse Training Program — for Registered Nurses, now enrolling."
               style="width:100%;height:auto;border-radius:14px;box-shadow:var(--shadow)" />
        </picture>
      </figure>
    </div>
  </section>

  <!-- Next batch -->
  <section class="section section--mist" style="padding-block:44px">
    <div class="container" style="max-width:900px">
      <p class="eyebrow">Next batch — now enrolling</p>
      <h2 style="margin-bottom:18px">July 20 – August 28, 2026</h2>
      <div class="grid grid--2">
        <div class="card">
          <p style="margin:0 0 .4rem"><strong>Schedule:</strong> Monday to Friday</p>
          <p style="margin:0 0 .4rem"><strong>Time:</strong> 8:00 AM – 4:00 PM</p>
          <p style="margin:0 0 .4rem"><strong>Format:</strong> On-site lecture + hands-on clinical exposure</p>
          <p style="margin:0"><strong>Attire:</strong> Emerald-green scrub suit</p>
        </div>
        <div class="card">
          <p style="margin:0 0 .4rem"><strong>Venue — Main Branch</strong></p>
          <p class="muted" style="margin:0 0 .6rem">St. John Biocare, Quezon Avenue<br/>2nd Floor, 1198 Casman Building, Barangay Paligsahan, Quezon Avenue, Quezon City 1100</p>
          <p style="margin:0"><strong>Inquiries:</strong>
            <a href="tel:+63283751575">+63 (2) 8375 1575</a> · <a href="tel:+63289218921">+63 (2) 8921 8921</a></p>
          <p style="margin:.3rem 0 0"><a href="https://www.facebook.com/sjbdc" target="_blank" rel="noopener">facebook.com/sjbdc</a></p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width:820px">
      <h2>What you'll learn</h2>
      <p>Through both classroom lectures and supervised clinical practice, you'll gain hands-on experience in:</p>
      <ul style="line-height:1.9">
        <li>Patient care and assessment</li>
        <li>Basic hemodialysis skills</li>
        <li>Vascular access safeguarding</li>
        <li>Infection-control protocols</li>
      </ul>
      <p>You'll learn from our senior renal nurses and key clinical leads, and — on successful completion —
      receive a <strong>Certificate of Training</strong> that can enhance your professional credentials.</p>

      <h2 style="margin-top:32px">Requirements</h2>
      <ul style="line-height:1.9">
        {requirements.map((r) => <li>{r}</li>)}
      </ul>
    </div>
  </section>

  <!-- Fees & payment -->
  <section class="section section--sand">
    <div class="container" style="max-width:820px">
      <h2>Training fee</h2>
      <div class="card">
        <p style="font-size:1.5rem;font-family:var(--font-head);color:var(--forest);margin:0 0 .3rem"><strong>₱14,000</strong> — cash or installment</p>
        <p class="muted" style="margin:0 0 .8rem">Inclusive of the HD in-house manual and HD consumables (gloves and N95 masks).</p>
        <p style="margin:0 0 .3rem"><strong>50% down payment (₱7,000)</strong> — on or before the training start.</p>
        <p style="margin:0"><strong>Remaining 50% balance</strong> — settled during the training period, at least two weeks before it ends.</p>
      </div>

      <h2 style="margin-top:30px">How to pay</h2>
      <div class="grid grid--2">
        <div class="card">
          <h3 style="font-size:1.15rem">Option 1 — Bank transfer</h3>
          <p style="margin:0 0 .3rem"><strong>Account name:</strong> St. John Biocare and Dialysis Center Foundation, Inc.</p>
          <p style="margin:0 0 .3rem"><strong>Bank:</strong> PBCOM — Quezon Avenue Branch</p>
          <p style="margin:0 0 .3rem"><strong>Savings account no.:</strong> 235 10 000905 3</p>
          <p class="muted" style="margin:.4rem 0 0">Kindly send your proof of payment after depositing.</p>
        </div>
        <div class="card">
          <h3 style="font-size:1.15rem">Option 2 — Pay at the cashier</h3>
          <p style="margin:0">You may also settle the payment on the same date as your training schedule, at the cashier.</p>
        </div>
      </div>

      <div class="notice" style="margin-top:22px">
        <strong>Ready to enroll or have questions?</strong> Call
        <a href="tel:+63283751575">+63 (2) 8375 1575</a> or
        <a href="tel:+63289218921">+63 (2) 8921 8921</a>, message us on
        <a href="https://www.facebook.com/sjbdc" target="_blank" rel="noopener">facebook.com/sjbdc</a>, or
        <a href="#register">register below</a>. Thank you for your continuous support.
      </div>
    </div>
  </section>

  <!-- INVITATION LETTER -->
  <section id="invitation" class="section">
    <div class="container" style="max-width:760px">
      <div class="center" style="margin-bottom:24px">
        <p class="eyebrow">Invitation letter</p>
        <h2>Take an invitation with you.</h2>
        <p class="muted">A one-page letter with the full programme details — useful for your chief nurse,
        your HR office, or your own records. Add your name and address and we'll address it to you
        personally; leave them blank for a general copy.</p>
      </div>

      <form class="card" id="inviteForm" novalidate>
        <div class="grid grid--2" style="gap:0 18px">
          <div class="form-field">
            <label for="inv-name">Your name <span class="muted" style="font-weight:400">(optional)</span></label>
            <input id="inv-name" type="text" autocomplete="name" placeholder="Ms. Maria Cristina D. Santos, RN" />
          </div>
          <div class="form-field">
            <label for="inv-addr1">Address line 1 <span class="muted" style="font-weight:400">(optional)</span></label>
            <input id="inv-addr1" type="text" autocomplete="address-line1" placeholder="Unit 12B, Cordillera Street" />
          </div>
        </div>
        <div class="form-field">
          <label for="inv-addr2">Address line 2 <span class="muted" style="font-weight:400">(optional)</span></label>
          <input id="inv-addr2" type="text" autocomplete="address-line2" placeholder="Quezon City 1113, Metro Manila" />
        </div>

        <div style="display:flex;gap:12px;flex-wrap:wrap;align-items:center;margin-top:18px">
          <button type="submit" class="btn btn--crimson" id="inv-btn">Download my invitation letter</button>
          <a class="btn btn--ghost" href="/downloads/hd-nurse-training-invitation.pdf" download>
            Download the general letter
          </a>
        </div>

        <p class="muted" style="font-size:.82rem;margin-top:14px">
          Your details are used only to write the letter — it is created on your own device and
          nothing is sent to us. To enroll, please use the
          <a href="#register">registration form below</a>.
        </p>
        <p id="inv-error" class="muted" style="font-size:.82rem;color:var(--crimson);margin-top:8px;display:none"></p>
      </form>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section--mist">
    <div class="container stack" style="max-width:760px">
      <div class="center" style="margin-bottom:26px">
        <p class="eyebrow">Common questions</p>
        <h2>The HD Nurse Training Program — answered.</h2>
      </div>
      {faqs.map((f) => (
        <details class="faq">
          <summary>{f.q}</summary>
          <div class="faq__a"><p style="margin:0">{f.a}</p></div>
        </details>
      ))}
      <p class="muted" style="font-size:.9rem;margin-top:8px">
        Still have a question? <a href="#register">Register below</a> or call
        <a href="tel:+63283751575">+63 (2) 8375 1575</a>.
      </p>
    </div>
  </section>

  <!-- Registration -->
  <section id="register" class="section">
    <div class="container" style="max-width:720px">
      <div class="center" style="margin-bottom:22px">
        <p class="eyebrow">Register</p>
        <h2>Apply for the HD Nurse Training Program</h2>
        <p class="muted">Fill in your details and upload your bank deposit slip. Your registration goes
        straight to our Nursing Director &amp; Head Faculty, <strong>Ms. Mercy J. Alhambra</strong>.</p>
      </div>

      <form class="card" action="https://api.web3forms.com/submit" method="POST" enctype="multipart/form-data">
        <!-- Web3Forms routing (key ties delivery to Ms. Alhambra's inbox) -->
        <input type="hidden" name="access_key" value="5b9d33f9-f3ca-4e4c-90bb-6b4163445a3b" />
        <input type="hidden" name="subject" value="New HD Nurse Training registration — stjohnbiocare.com" />
        <input type="hidden" name="from_name" value="St. John Biocare — HD Training" />
        <input type="hidden" name="redirect" value="https://stjohnbiocare.com/thank-you/" />
        <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off" />

        <div class="grid grid--2" style="gap:0 18px">
          <div class="form-field">
            <label for="rn-name">Full name</label>
            <input id="rn-name" name="Full name" type="text" required autocomplete="name" />
          </div>
          <div class="form-field">
            <label for="rn-prc">PRC license no.</label>
            <input id="rn-prc" name="PRC license number" type="text" required />
          </div>
        </div>

        <div class="grid grid--2" style="gap:0 18px">
          <div class="form-field">
            <label for="rn-email">Email</label>
            <input id="rn-email" name="email" type="email" required />
          </div>
          <div class="form-field">
            <label for="rn-mobile">Mobile number</label>
            <input id="rn-mobile" name="Mobile number" type="tel" required />
          </div>
        </div>

        <div class="grid grid--2" style="gap:0 18px">
          <div class="form-field">
            <label for="rn-batch">Training batch</label>
            <input id="rn-batch" name="Training batch" type="text" value="July 20 – August 28, 2026" />
          </div>
          <div class="form-field">
            <label for="rn-pay">Payment option</label>
            <select id="rn-pay" name="Payment option">
              <option>Bank transfer (deposit slip attached)</option>
              <option>Will pay at the cashier</option>
            </select>
          </div>
        </div>

        <div class="form-field">
          <label for="rn-files">Upload your documents</label>
          <input id="rn-files" name="attachment" type="file" accept="image/*,application/pdf" multiple />
          <p class="muted" style="font-size:.82rem;margin:.3rem 0 0">
            Select multiple files (JPG, PNG or PDF, up to ~5&nbsp;MB total): <strong>bank deposit slip</strong>,
            updated <strong>résumé</strong>, <strong>PRC ID</strong>, <strong>Hepatitis profile</strong>
            result, and <strong>vaccination records</strong>. If your files are larger than 5&nbsp;MB, upload
            the deposit slip here and bring the rest on your first day.
          </p>
        </div>

        <div class="form-field">
          <label for="rn-msg">Message (optional)</label>
          <textarea id="rn-msg" name="Message" placeholder="Anything you'd like us to know."></textarea>
        </div>

        <label class="consent">
          <input type="checkbox" name="Consent (Data Privacy Act)" required />
          <span>I agree that St. John Biocare may process my information for this training registration,
          in line with the Data Privacy Act of 2012 (RA&nbsp;10173).</span>
        </label>

        <div style="margin-top:18px">
          <button type="submit" class="btn btn--crimson">Submit registration</button>
        </div>
        <p class="muted" style="font-size:.82rem;margin-top:12px">
          Please also bring your original requirements — résumé, PRC ID, Hepatitis profile and vaccination
          records — on your first day.
        </p>
      </form>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  })} />
</BaseLayout>

<style>
  .faq { background: var(--white); border: 1px solid var(--border); border-radius: var(--radius); padding: 4px 22px; box-shadow: var(--shadow); }
  .faq summary { cursor: pointer; font-weight: 700; color: var(--forest); font-family: var(--font-head); font-size: 1.1rem; padding: 16px 0; list-style: none; display: flex; justify-content: space-between; gap: 12px; }
  .faq summary::-webkit-details-marker { display: none; }
  .faq summary::after { content: '+'; color: var(--life); font-weight: 700; font-size: 1.4rem; line-height: 1; }
  .faq[open] summary::after { content: '\2212'; }
  .faq__a { padding: 0 0 18px; color: var(--ink-soft); }
</style>

<script>
  // Personalised invitation letter.
  //
  // The designed letter lives at /downloads/hd-nurse-training-invitation-template.pdf
  // with a deliberately blank recipient block. We stamp the visitor's name, address
  // and salutation onto it here, in their own browser — nothing is uploaded, and no
  // server is involved (the site is static). Anchors below come from the generator
  // in tools/make_invitation_letter.py; if the letter is redesigned, re-run it and
  // copy the new letter-anchors.json values across.
  import { PDFDocument, StandardFonts, rgb } from 'pdf-lib';

  const TEMPLATE = '/downloads/hd-nurse-training-invitation-template.pdf';
  const MM = 2.834645;

  const ANCHOR = { recipTop: 685.7, salutY: 631.84, left: 45.35 };
  const INK  = rgb(0x22 / 255, 0x2A / 255, 0x24 / 255);
  const SOFT = rgb(0x5F / 255, 0x6B / 255, 0x60 / 255);

  const form = document.getElementById('inviteForm');

  if (form) {
    const btn = document.getElementById('inv-btn');
    const err = document.getElementById('inv-error');

    const slug = (s) =>
      s.normalize('NFD').replace(/[̀-ͯ]/g, '')
       .replace(/[^A-Za-z0-9]+/g, '-').replace(/^-+|-+$/g, '').slice(0, 48);

    // Helvetica (a standard PDF font) has no glyphs beyond Latin-1, so strip
    // anything it cannot draw rather than letting pdf-lib throw.
    const safe = (s) => s.replace(/[^\x20-\xFF]/g, '');

    // "Ms. Maria Cristina D. Santos, RN" -> "Dear Ms. Santos,"
    // Drop post-comma credentials, then prefer <title> + <surname>. Without a
    // recognisable title we simply use the name as given, which is never wrong.
    const salutationFor = (full) => {
      if (!full) return 'Dear Colleague,';
      const clean = full.split(',')[0].trim().replace(/\s+/g, ' ');
      const parts = clean.split(' ').filter(Boolean);
      const TITLES = ['mr', 'mrs', 'ms', 'miss', 'dr', 'prof'];
      const first = (parts[0] || '').toLowerCase().replace(/\./g, '');
      if (parts.length >= 2 && TITLES.includes(first)) {
        return `Dear ${parts[0]} ${parts[parts.length - 1]},`;
      }
      return `Dear ${clean},`;
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      err.style.display = 'none';
      const original = btn.textContent;
      btn.disabled = true;
      btn.textContent = 'Preparing your letter…';

      try {
        const name  = safe(document.getElementById('inv-name').value.trim());
        const addr1 = safe(document.getElementById('inv-addr1').value.trim());
        const addr2 = safe(document.getElementById('inv-addr2').value.trim());

        const res = await fetch(TEMPLATE);
        if (!res.ok) throw new Error('template ' + res.status);
        const pdf = await PDFDocument.load(await res.arrayBuffer());

        const page = pdf.getPages()[0];
        const reg  = await pdf.embedFont(StandardFonts.Helvetica);
        const bold = await pdf.embedFont(StandardFonts.HelveticaBold);

        const today = new Date().toLocaleDateString('en-GB', {
          day: 'numeric', month: 'long', year: 'numeric',
        });

        let y = ANCHOR.recipTop;
        page.drawText(today, { x: ANCHOR.left, y, size: 8.6, font: reg, color: SOFT });

        if (name) {
          y -= 4.8 * MM;
          page.drawText(name, { x: ANCHOR.left, y, size: 9.6, font: bold, color: INK });
          y -= 4.4 * MM;
          for (const line of [addr1, addr2].filter(Boolean)) {
            page.drawText(line, { x: ANCHOR.left, y, size: 8.8, font: reg, color: SOFT });
            y -= 4.2 * MM;
          }
        }

        page.drawText(salutationFor(name), {
          x: ANCHOR.left, y: ANCHOR.salutY, size: 10.2, font: bold, color: INK,
        });

        pdf.setTitle('Invitation — Hemodialysis Nurse Training Program');
        const bytes = await pdf.save();
        const url = URL.createObjectURL(new Blob([bytes], { type: 'application/pdf' }));
        const a = document.createElement('a');
        a.href = url;
        a.download = name
          ? `SJB-HD-Training-Invitation-${slug(name)}.pdf`
          : 'SJB-HD-Training-Invitation.pdf';
        document.body.appendChild(a);
        a.click();
        a.remove();
        setTimeout(() => URL.revokeObjectURL(url), 4000);
      } catch (e) {
        // Never leave someone stuck: fall back to the plain letter.
        err.textContent =
          "We couldn't personalise the letter just now — the general copy is downloading instead.";
        err.style.display = 'block';
        window.location.href = '/downloads/hd-nurse-training-invitation.pdf';
      } finally {
        btn.disabled = false;
        btn.textContent = original;
      }
    });
  }
</script>
