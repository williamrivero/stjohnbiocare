---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';

const highlights = [
  { t: '6-week program', d: 'A focused, comprehensive course from the ground up.' },
  { t: 'Didactic + hands-on', d: 'Classroom lectures plus supervised clinical exposure.' },
  { t: 'Expert instruction', d: 'Led by our senior renal nurses and key clinical leads.' },
  { t: 'Certificate of Training', d: 'Earn a certificate that strengthens your credentials.' },
];

const requirements = [
  'Updated résumé',
  'Photocopy of PRC ID',
  'Updated Hepatitis profile result (Anti-HCV, Anti-HBs and HBsAg)',
  'Vaccination ID / passport (COVID-19 vaccination records)',
];
---
<BaseLayout title="Training Academy" description="The St. John Biocare Hemodialysis Nurse Training Program for Registered Nurses — 6 weeks, didactic + hands-on, with a Certificate of Training. Next batch: July 20 – August 28, 2026." image="/images/photos/dsc_0026.webp">
  <PageHero
    image="/images/photos/dsc_0026.webp"
    alt="A St. John Biocare senior nurse reviewing a patient chart with two trainee nurses"
    eyebrow="Training Academy"
    title="We train the nurses others hire."
    subtitle="A high-quality Hemodialysis (HD) Training Program that develops your skills and molds you into a competent, proactive HD nurse."
  />

  <section class="section">
    <div class="container" style="max-width:900px">
      <p class="eyebrow">Hemodialysis Nurse Training Program</p>
      <h2>Come and be part of our team.</h2>
      <p class="lead">We invite all <strong>Registered Nurses (RNs)</strong> to join our growing team. St. John
      Biocare &amp; Dialysis Center offers a hands-on HD training course led by experienced renal nurses.</p>

      <div class="grid grid--2" style="margin-top:22px">
        {highlights.map((h) => (
          <div class="card"><h3 style="font-size:1.15rem">{h.t}</h3><p style="margin:0">{h.d}</p></div>
        ))}
      </div>
    </div>
  </section>

  <!-- Next batch -->
  <section class="section section--mist" style="padding-block:44px">
    <div class="container" style="max-width:900px">
      <p class="eyebrow">Next batch — now enrolling</p>
      <h2 style="margin-bottom:18px">July 20 – August 28, 2026</h2>
      <div class="grid grid--2">
        <div class="card">
          <p style="margin:0 0 .4rem"><strong>Schedule:</strong> Monday to Friday</p>
          <p style="margin:0 0 .4rem"><strong>Time:</strong> 8:00 AM – 4:00 PM</p>
          <p style="margin:0 0 .4rem"><strong>Format:</strong> On-site lecture + hands-on clinical exposure</p>
          <p style="margin:0"><strong>Attire:</strong> Emerald-green scrub suit</p>
        </div>
        <div class="card">
          <p style="margin:0 0 .4rem"><strong>Venue — Main Branch</strong></p>
          <p class="muted" style="margin:0 0 .6rem">St. John Biocare, Quezon Avenue<br/>2nd Floor, 1198 Casman Building, Barangay Paligsahan, Quezon Avenue, Quezon City 1100</p>
          <p style="margin:0"><strong>Inquiries:</strong>
            <a href="tel:+63283751575">+63 (2) 8375 1575</a> · <a href="tel:+63289218921">+63 (2) 8921 8921</a></p>
          <p style="margin:.3rem 0 0"><a href="https://www.facebook.com/sjbdc" target="_blank" rel="noopener">facebook.com/sjbdc</a></p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width:820px">
      <h2>What you'll learn</h2>
      <p>Through both classroom lectures and supervised clinical practice, you'll gain hands-on experience in:</p>
      <ul style="line-height:1.9">
        <li>Patient care and assessment</li>
        <li>Basic hemodialysis skills</li>
        <li>Vascular access safeguarding</li>
        <li>Infection-control protocols</li>
      </ul>
      <p>You'll learn from our senior renal nurses and key clinical leads, and — on successful completion —
      receive a <strong>Certificate of Training</strong> that can enhance your professional credentials.</p>

      <h2 style="margin-top:32px">Requirements</h2>
      <ul style="line-height:1.9">
        {requirements.map((r) => <li>{r}</li>)}
      </ul>
    </div>
  </section>

  <!-- Fees & payment -->
  <section class="section section--sand">
    <div class="container" style="max-width:820px">
      <h2>Training fee</h2>
      <div class="card">
        <p style="font-size:1.5rem;font-family:var(--font-head);color:var(--forest);margin:0 0 .3rem"><strong>₱14,000</strong> — cash or installment</p>
        <p class="muted" style="margin:0 0 .8rem">Inclusive of the HD in-house manual and HD consumables (gloves, masks, etc.).</p>
        <p style="margin:0 0 .3rem"><strong>50% down payment (₱7,000)</strong> — on or before the training start.</p>
        <p style="margin:0"><strong>Remaining 50% balance</strong> — settled during the training period, at least two weeks before it ends.</p>
      </div>

      <h2 style="margin-top:30px">How to pay</h2>
      <div class="grid grid--2">
        <div class="card">
          <h3 style="font-size:1.15rem">Option 1 — Bank transfer</h3>
          <p style="margin:0 0 .3rem"><strong>Account name:</strong> St. John Biocare and Dialysis Center Foundation, Inc.</p>
          <p style="margin:0 0 .3rem"><strong>Bank:</strong> PBCOM — Quezon Avenue Branch</p>
          <p style="margin:0 0 .3rem"><strong>Savings account no.:</strong> 235 10 000905 3</p>
          <p class="muted" style="margin:.4rem 0 0">Kindly send your proof of payment after depositing.</p>
        </div>
        <div class="card">
          <h3 style="font-size:1.15rem">Option 2 — Pay at the cashier</h3>
          <p style="margin:0">You may also settle the payment on the same date as your training schedule, at the cashier.</p>
        </div>
      </div>

      <div class="notice" style="margin-top:22px">
        <strong>Ready to enroll or have questions?</strong> Call
        <a href="tel:+63283751575">+63 (2) 8375 1575</a> or
        <a href="tel:+63289218921">+63 (2) 8921 8921</a>, message us on
        <a href="https://www.facebook.com/sjbdc" target="_blank" rel="noopener">facebook.com/sjbdc</a>, or
        <a href="#register">register below</a>. Thank you for your continuous support.
      </div>
    </div>
  </section>

  <!-- Registration -->
  <section id="register" class="section">
    <div class="container" style="max-width:720px">
      <div class="center" style="margin-bottom:22px">
        <p class="eyebrow">Register</p>
        <h2>Apply for the HD Nurse Training Program</h2>
        <p class="muted">Fill in your details and upload your bank deposit slip. Your registration goes
        straight to our Nursing Director &amp; Head Faculty, <strong>Ms. Mercy J. Alhambra</strong>.</p>
      </div>

      <form class="card" action="https://api.web3forms.com/submit" method="POST" enctype="multipart/form-data">
        <!-- Web3Forms routing (key ties delivery to Ms. Alhambra's inbox) -->
        <input type="hidden" name="access_key" value="YOUR_WEB3FORMS_KEY" />
        <input type="hidden" name="subject" value="New HD Nurse Training registration — stjohnbiocare.com" />
        <input type="hidden" name="from_name" value="St. John Biocare — HD Training" />
        <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off" />

        <div class="grid grid--2" style="gap:0 18px">
          <div class="form-field">
            <label for="rn-name">Full name</label>
            <input id="rn-name" name="Full name" type="text" required autocomplete="name" />
          </div>
          <div class="form-field">
            <label for="rn-prc">PRC license no.</label>
            <input id="rn-prc" name="PRC license number" type="text" required />
          </div>
        </div>

        <div class="grid grid--2" style="gap:0 18px">
          <div class="form-field">
            <label for="rn-email">Email</label>
            <input id="rn-email" name="email" type="email" required />
          </div>
          <div class="form-field">
            <label for="rn-mobile">Mobile number</label>
            <input id="rn-mobile" name="Mobile number" type="tel" required />
          </div>
        </div>

        <div class="grid grid--2" style="gap:0 18px">
          <div class="form-field">
            <label for="rn-batch">Training batch</label>
            <input id="rn-batch" name="Training batch" type="text" value="July 20 – August 28, 2026" />
          </div>
          <div class="form-field">
            <label for="rn-pay">Payment option</label>
            <select id="rn-pay" name="Payment option">
              <option>Bank transfer (deposit slip attached)</option>
              <option>Will pay at the cashier</option>
            </select>
          </div>
        </div>

        <div class="form-field">
          <label for="rn-files">Upload your documents</label>
          <input id="rn-files" name="attachment" type="file" accept="image/*,application/pdf" multiple />
          <p class="muted" style="font-size:.82rem;margin:.3rem 0 0">
            Select multiple files (JPG, PNG or PDF, up to ~5&nbsp;MB total): <strong>bank deposit slip</strong>,
            updated <strong>résumé</strong>, <strong>PRC ID</strong>, <strong>Hepatitis profile</strong>
            result, and <strong>vaccination records</strong>. If your files are larger than 5&nbsp;MB, upload
            the deposit slip here and bring the rest on your first day.
          </p>
        </div>

        <div class="form-field">
          <label for="rn-msg">Message (optional)</label>
          <textarea id="rn-msg" name="Message" placeholder="Anything you'd like us to know."></textarea>
        </div>

        <label class="consent">
          <input type="checkbox" name="Consent (Data Privacy Act)" required />
          <span>I agree that St. John Biocare may process my information for this training registration,
          in line with the Data Privacy Act of 2012 (RA&nbsp;10173).</span>
        </label>

        <div style="margin-top:18px">
          <button type="submit" class="btn btn--crimson">Submit registration</button>
        </div>
        <p class="muted" style="font-size:.82rem;margin-top:12px">
          Please also bring your original requirements — résumé, PRC ID, Hepatitis profile and vaccination
          records — on your first day.
        </p>
      </form>
    </div>
  </section>
</BaseLayout>
