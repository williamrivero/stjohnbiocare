---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { branches, foundations } from '../../data/branches';
const mapsUrl = (b) => `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(`${b.foundation} ${b.name}, ${b.address}`)}`;
const wazeUrl = (b) => `https://waze.com/ul?q=${encodeURIComponent(`${b.foundation} ${b.name}, ${b.address}`)}&navigate=yes`;
const openCount = branches.filter((b) => !b.underConstruction).length;
const soonCount = branches.filter((b) => b.underConstruction).length;
const foundationLogo = {
  'St. John Biocare': '/images/logos/logo-sjbdc.webp',
  'Core Renal Center': '/images/logos/corerenalcare-logo.webp',
  'St. Josef Renal Care Foundation': '/images/logos/stjosef-logo.webp',
};
// Flip to true once the survey page is live at stjohnbiocare.com/survey/
const surveyLive = true;
---
<BaseLayout title="Our Centers" description="St. John Biocare, Core Renal Center and St. Josef Renal Care hemodialysis centers across Metro Manila, Rizal and Bulacan — addresses, hours and directions." image="/images/og/og-centers.jpg">
  <PageHero
    image="/images/heroes/centers-hero.webp"
    alt="A bright, welcoming St. John Biocare dialysis floor with a nurse attending to a patient"
    eyebrow="Our centers"
    title="Our centers across Metro Manila & Bulacan."
    subtitle={`Our growing network — St. John Biocare, Core Renal Center and our sister foundation St. Josef Renal Care — has ${openCount} centers open now, with ${soonCount} more opening this year. Each runs six days a week from 5:30 AM.`}
  />

  <section class="ah-band" data-oh-notice hidden>
    <div class="container">
      <p class="ah-band__eyebrow">After 5:00 PM</p>
      <p class="ah-band__text">
        <strong>Trying to reach a center after 5:00&nbsp;PM?</strong> Our phone lines rest for the evening —
        open a center below and send it a message. We'll get back to you first thing in the morning.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {foundations.map((foundation) => {
        const group = branches.filter((b) => b.foundation === foundation);
        if (!group.length) return null;
        return (
          <div style="margin-bottom:44px">
            <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px">
              {foundationLogo[foundation] && <img src={foundationLogo[foundation]} alt={`${foundation} logo`} width="44" height="44" style="width:44px;height:44px;object-fit:contain" loading="lazy" />}
              <h2 style="font-size:1.5rem;margin:0">{foundation}</h2>
            </div>
            <div class="grid grid--2">
              {group.map((b) => (
                <div class="card">
                  <div style="display:flex;justify-content:space-between;align-items:center;gap:10px;margin-bottom:10px">
                    <div style="display:flex;align-items:center;gap:10px">
                      {foundationLogo[b.foundation] && <img src={foundationLogo[b.foundation]} alt={`${b.foundation} logo`} width="34" height="34" style="width:34px;height:34px;object-fit:contain;flex:0 0 auto" loading="lazy" />}
                      <span class="pill">{b.area}</span>
                    </div>
                    {b.underConstruction && (
                      <span class="pill" style="background:#fff2d9;color:#9a6a00">Opening this year</span>
                    )}
                  </div>
                  <h3 style="font-size:1.35rem;margin-bottom:.3rem">{b.name}</h3>
                  {b.underConstruction ? (
                    <>
                      <p class="muted" style="margin-bottom:.6rem">A new center is under construction here and will open this year.</p>
                      {!/opening this year/i.test(b.address) && (
                        <>
                          <p class="muted" style="margin-bottom:.8rem">{b.address}</p>
                          <div style="display:flex;gap:10px;flex-wrap:wrap">
                            <a class="btn btn--primary" href={`/centers/${b.slug}`}>View center</a>
                            <a class="btn btn--ghost" target="_blank" rel="noopener" href={mapsUrl(b)}>Google Maps</a>
                          </div>
                        </>
                      )}
                    </>
                  ) : (
                    <>
                      <p class="muted" style="margin-bottom:.5rem">{b.address}</p>
                      <p style="margin-bottom:.3rem"><strong>Hours:</strong> {b.hours}</p>
                      <p style="margin-bottom:1rem"><strong>Phone:</strong> {b.phone}</p>
                      <div style="display:flex;gap:10px;flex-wrap:wrap">
                        <a class="btn btn--primary" href={`/centers/${b.slug}`}>View center</a>
                        <a class="btn btn--ghost" target="_blank" rel="noopener" href={mapsUrl(b)}>Google Maps</a>
                        <a class="btn btn--ghost" target="_blank" rel="noopener" href={wazeUrl(b)}>Waze</a>
                      </div>
                    </>
                  )}
                </div>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <section class="section section--sand" style="padding-block:44px">
    <div class="container" style="max-width:920px">
      <figure style="margin:0">
        <picture>
          <source srcset="/images/og/og-centers.webp" type="image/webp" />
          <img src="/images/og/og-centers.jpg" width="1200" height="630" loading="lazy"
               alt="St. John Biocare and St. Josef Renal Care dialysis centers across Metro Manila and Bulacan."
               style="width:100%;height:auto;border-radius:14px;box-shadow:var(--shadow)" />
        </picture>
      </figure>
    </div>
  </section>

  <!-- PATIENT SATISFACTION SURVEY — for patients only; links to the shared canonical survey.
       Hidden until the survey page is live (set surveyLive=true above). -->
  {surveyLive && (
  <section id="patient-survey" class="section" style="padding-top:0;scroll-margin-top:90px">
    <div class="container" style="max-width:860px">
      <div class="card" style="border-left:5px solid var(--life)">
        <div style="display:flex;gap:32px;flex-wrap:wrap;align-items:center">
          <div style="flex:1 1 340px;min-width:0">
            <span class="pill" style="background:var(--mist);color:var(--forest);font-weight:700">For patients only</span>
            <h2 style="font-size:1.5rem;margin:12px 0 8px">Patient Satisfaction Survey</h2>
            <p style="margin:0 0 14px">Are you a dialysis patient at one of our centers? Please tell us how we are doing.
            Your feedback is <strong>confidential and anonymous</strong> — you do not need to give your name, and your
            answers will <strong>never affect your treatment</strong> in any way.</p>
            <ul style="margin:0 0 18px;padding-left:20px;line-height:1.7">
              <li>Choose your <strong>center and branch</strong>, then rate your care.</li>
              <li>Takes about <strong>3–5 minutes</strong> — you can do it on your phone.</li>
              <li>Your response goes straight to your branch team.</li>
            </ul>
            <a class="btn btn--primary" href="/survey/">Start the survey →</a>
            <p class="muted" style="margin:14px 0 0;font-size:.85rem">This survey is for current patients and their
            families. If you are not a patient here, please do not submit a response.</p>
          </div>
          <figure style="flex:0 0 auto;margin:0 auto;text-align:center">
            <img src="/images/survey-qr.svg" alt="QR code that opens the Patient Satisfaction Survey" width="210" height="210"
                 style="width:210px;height:210px;display:block;border:1px solid var(--border);border-radius:16px;padding:12px;background:#fff;box-shadow:var(--shadow)" />
            <figcaption class="muted" style="margin:10px auto 0;font-size:.85rem;font-weight:600;max-width:210px">Scan to open the survey</figcaption>
          </figure>
        </div>
      </div>
    </div>
  </section>
  )}

  <script is:inline>
    // Phone lines are attended Mon–Sat, 5:30 AM – 5:00 PM (Asia/Manila).
    // Outside that window, show the notice pointing people to the message form.
    (function () {
      var notice = document.querySelector('[data-oh-notice]');
      if (!notice) return;

      // Preview override: ?after-hours=1 forces the notice on, ?after-hours=0 forces it off.
      var force = new URLSearchParams(location.search).get('after-hours');

      function attended() {
        if (force === '1') return false;
        if (force === '0') return true;
        var now = new Date(
          new Date().toLocaleString('en-US', { timeZone: 'Asia/Manila' })
        );
        var day = now.getDay();               // 0 = Sunday
        var mins = now.getHours() * 60 + now.getMinutes();
        return day !== 0 && mins >= 5 * 60 + 30 && mins < 17 * 60;
      }

      function update() { notice.hidden = attended(); }

      update();
      setInterval(update, 60000);
    })();
  </script>
</BaseLayout>

<style>
  .ah-band { background: var(--sand); padding: 22px 0; }
  .ah-band[hidden] { display: none; }
  .ah-band__eyebrow {
    margin: 0 0 6px; font-size: .72rem; font-weight: 700; letter-spacing: .09em;
    text-transform: uppercase; color: var(--ink-soft);
  }
  .ah-band__text { margin: 0; max-width: 72ch; color: var(--ink); line-height: 1.6; }
  .ah-band__text strong { color: var(--crimson); }
</style>
