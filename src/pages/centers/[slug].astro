---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { branches } from '../../data/branches';
import { site } from '../../data/site';

// One page is generated for each branch in src/data/branches.ts
export function getStaticPaths() {
  return branches.map((b) => ({ params: { slug: b.slug }, props: { branch: b } }));
}

const { branch } = Astro.props;
const q = encodeURIComponent(`${branch.name} St. John Biocare, ${branch.address}`);
const mapSrc = `https://maps.google.com/maps?q=${q}&z=16&output=embed`;
const directions = `https://www.google.com/maps/dir/?api=1&destination=${q}`;
const waze = `https://waze.com/ul?q=${q}&navigate=yes`;
---
<BaseLayout
  title={`${branch.name} Center`}
  description={`St. John Biocare ${branch.name} — ${branch.address}. Hours, team, services and directions.`}
>
  <section class="section" style="background:linear-gradient(180deg,var(--mist),var(--cream));padding-block:44px">
    <div class="container">
      <a href="/centers" style="font-weight:700;text-decoration:none">← All centers</a>
      <span class="pill" style="margin:14px 0 8px;display:inline-flex">{branch.area}</span>
      <h1>{branch.name}</h1>
      <p class="lead">{branch.address}</p>
      <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:16px">
        <a class="btn btn--crimson" href="/new-patients#request">Request an appointment</a>
        <a class="btn btn--ghost" target="_blank" rel="noopener" href={directions}>Google Maps</a>
        <a class="btn btn--ghost" target="_blank" rel="noopener" href={waze}>Waze</a>
        <a class="btn btn--ghost" href={branch.phoneHref}>Call the center</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container branch">
      <div class="branch__main stack">
        <div class="map-frame">
          <iframe
            src={mapSrc}
            title={`Map to ${branch.name}`}
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            style="border:0;width:100%;height:100%"></iframe>
        </div>

        <div class="card">
          <h2 style="font-size:1.4rem">On-site services</h2>
          <ul style="margin:0;padding-left:1.1rem;line-height:1.9">
            {branch.services.map((s) => <li>{s}</li>)}
          </ul>
        </div>

        <div class="card">
          <h2 style="font-size:1.4rem">Getting here</h2>
          <p>{branch.transit}</p>
          <p style="margin:0"><strong>Directions:</strong>
            <a href={directions} target="_blank" rel="noopener">Google Maps</a> ·
            <a href={waze} target="_blank" rel="noopener">Waze</a>
          </p>
        </div>
      </div>

      <aside class="branch__side stack">
        <div class="card">
          <h3>Hours</h3>
          <p style="margin:0">{branch.hours}</p>
          <p class="muted" style="font-size:.85rem;margin-top:.4rem">
            Also open on public holidays unless otherwise arranged.
          </p>
        </div>
        <div class="card">
          <h3>Contact</h3>
          <p style="margin:0 0 .3rem"><strong>Phone:</strong> <a href={branch.phoneHref}>{branch.phone}</a></p>
          <p style="margin:0"><strong>Email:</strong> <a href={`mailto:${branch.email}`}>{branch.email}</a></p>
        </div>
        <div class="card">
          <h3>Care team</h3>
          <p style="margin:0 0 .3rem"><strong>Medical Director:</strong> {branch.medicalDirector}</p>
          <p style="margin:0 0 .3rem"><strong>Head Nurse:</strong> {branch.headNurse}</p>
          {branch.stations && <p style="margin:0"><strong>Dialysis stations:</strong> {branch.stations}</p>}
        </div>
      </aside>
    </div>
  </section>

  <section class="section section--forest center">
    <div class="container" style="max-width:640px">
      <h2>Ready to visit {branch.name}?</h2>
      <p style="color:#e5f3e9">Send a short request and our team will get back to you.</p>
      <a href="/new-patients#request" class="btn btn--light" style="margin-top:8px">Request an appointment</a>
    </div>
  </section>
</BaseLayout>

<style>
  .branch { display: grid; grid-template-columns: 1.6fr .9fr; gap: 26px; align-items: start; }
  @media (max-width: 860px) { .branch { grid-template-columns: 1fr; } }
  .map-frame { border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow); height: 340px; background: var(--sand); }
  .branch h3 { font-size: 1.15rem; margin-bottom: .4rem; }
</style>
