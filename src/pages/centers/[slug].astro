---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { branches } from '../../data/branches';
import { site } from '../../data/site';
import { centerKeys } from '../../data/centerKeys';
import QRCode from 'qrcode';

// A page is generated for every open center, plus any under-construction center
// that already has a real street address (so it can show a precise map).
export function getStaticPaths() {
  return branches
    .filter((b) => !b.underConstruction || !/opening this year/i.test(b.address))
    .map((b) => ({ params: { slug: b.slug }, props: { branch: b } }));
}

const { branch } = Astro.props;
const uc = !!branch.underConstruction;
const centerKey = centerKeys[branch.slug];
// While a center is under construction, its inquiries are handled by a nearby open center.
const inquiryBranch = uc && branch.inquiriesVia ? branches.find((b) => b.slug === branch.inquiriesVia) : null;
const inquiryKey = inquiryBranch ? centerKeys[inquiryBranch.slug] : null;
// A precise drop-pin ("lat,lng") wins when set. Otherwise: open centers lead with the
// business name so Google matches the established place; under-construction branches
// (not yet on Google) pin by street address so they don't snap to a same-foundation center.
const q = encodeURIComponent(
  branch.mapPin
    ? branch.mapPin
    : branch.underConstruction
      ? branch.address
      : `${branch.foundation} ${branch.name}, ${branch.address}`
);

// Build a vCard for this center and render it as a scannable QR (contact card).
const tel = branch.phoneHref.replace('tel:', '');
const vcard = [
  'BEGIN:VCARD',
  'VERSION:3.0',
  `FN:${branch.foundation} — ${branch.name}`,
  `ORG:${branch.foundation}`,
  `TEL;TYPE=WORK,VOICE:${tel}`,
  branch.email ? `EMAIL;TYPE=WORK:${branch.email}` : '',
  `ADR;TYPE=WORK:;;${branch.address.replace(/,/g, ' ')};;;;Philippines`,
  `URL:https://stjohnbiocare.com/centers/${branch.slug}`,
  'END:VCARD',
].filter(Boolean).join('\n');
const qrSvg = await QRCode.toString(vcard, {
  type: 'svg',
  margin: 1,
  errorCorrectionLevel: 'M',
  color: { dark: '#006028', light: '#ffffff' },
});
const vcardHref = `data:text/vcard;charset=utf-8,${encodeURIComponent(vcard)}`;
const mapSrc = `https://maps.google.com/maps?q=${q}&z=16&output=embed`;
const directions = `https://www.google.com/maps/dir/?api=1&destination=${q}`;
const waze = `https://waze.com/ul?q=${q}&navigate=yes`;
const foundationLogo = {
  'St. John Biocare': '/images/logos/logo-sjbdc.webp',
  'Core Renal Center': '/images/logos/corerenalcare-logo.webp',
  'St. Josef Renal Care Foundation': '/images/logos/stjosef-logo.webp',
}[branch.foundation];

// "Years serving the community" — counted the same way the brand counts its own
// milestones ("fifteen years since 2011"): calendar-year difference from opening.
const sinceYear = branch.opened ? Number(branch.opened.slice(0, 4)) : null;
const yearsServing = sinceYear ? new Date().getFullYear() - sinceYear : null;

// Hospital care: prefer signed MOA partners. Where no MOA exists yet (e.g. Caloocan,
// still under negotiation) we fall back to nearby hospitals — clearly labelled as such,
// never implying an agreement we don't have.
const hasMoa = !!(branch.partnerHospitals && branch.partnerHospitals.length > 0);
const hospitalList = hasMoa ? branch.partnerHospitals! : (branch.nearbyHospitals ?? []);
---
<BaseLayout
  title={`${branch.name} Center`}
  description={`${branch.foundation} — ${branch.name}, ${branch.address}. Hours, team, services and directions.`}
  image={uc ? '/images/og/og-centers.jpg' : `/images/og/centers/${branch.slug}.jpg`}
>
  <section class="section" style="background:linear-gradient(180deg,var(--mist),var(--cream));padding-block:44px">
    <div class="container">
      <a href="/centers" style="font-weight:700;text-decoration:none">← All centers</a>
      <div style="margin:14px 0 8px">
        <span class="pill" style="display:inline-flex">{branch.area}</span>
        {uc && <span class="pill" style="background:#fff2d9;color:#9a6a00;margin-left:8px;display:inline-flex">Opening this year</span>}
      </div>
      <p class="eyebrow" style="margin:0 0 2px">{branch.foundation}</p>
      <h1>{branch.name}</h1>
      <p class="lead">{branch.address}</p>
      {!uc && yearsServing && yearsServing >= 1 && (
        <p class="serving-badge">
          <span aria-hidden="true">🤍</span>
          <strong>{yearsServing} {yearsServing === 1 ? 'year' : 'years'}</strong> serving the community
          <span class="serving-since">· since {sinceYear}</span>
        </p>
      )}
      <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:16px">
        <a class="btn btn--ghost" target="_blank" rel="noopener" href={directions}>Google Maps</a>
        <a class="btn btn--ghost" target="_blank" rel="noopener" href={waze}>Waze</a>
        {!uc && <a class="btn btn--crimson" href="/new-patients#request">Request an appointment</a>}
        {!uc && <a class="btn btn--ghost" data-oh-call href={branch.phoneHref}>Call the center</a>}
        {!uc && centerKey && <a class="btn btn--ghost" href="#message">Message this center</a>}
        {uc && <a class="btn btn--primary" href="/centers">See open centers</a>}
      </div>
    </div>
  </section>

  {uc && (
    <>
    <section class="section">
      <div class="container" style="max-width:860px">
        <div class="map-frame">
          <iframe
            src={mapSrc}
            title={`Map to ${branch.name}`}
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            style="border:0;width:100%;height:100%"></iframe>
        </div>
        <div class="notice" style="margin-top:22px">
          <strong>Opening this year.</strong> Our new {branch.foundation} branch at {branch.address} is
          under construction and will open soon.{inquiryBranch && <> In the meantime, inquiries for this
          branch are warmly handled by our nearby <strong>{inquiryBranch.name}</strong> center.</>}
        </div>
        <div style="margin-top:16px;display:flex;gap:12px;flex-wrap:wrap">
          <a class="btn btn--primary" href="/centers">See open centers</a>
          <a class="btn btn--ghost" href="/new-patients#request">Request an appointment</a>
        </div>
      </div>
    </section>

    {inquiryBranch && (
      <section id="message" class="section section--sand">
        <div class="container" style="max-width:640px">
          <div class="center" style="margin-bottom:20px">
            <p class="eyebrow">Have a question already?</p>
            <h2>Ask us about {branch.name}.</h2>
            <p class="muted">While this branch is being built, our <strong>{inquiryBranch.name}</strong>
            team is happy to help — call <a href={inquiryBranch.phoneHref}>{inquiryBranch.phone}</a> or
            email <a href={`mailto:${inquiryBranch.email}`}>{inquiryBranch.email}</a>, or send a message below.</p>
          </div>
          {inquiryKey && (
            <form class="card" action="https://api.web3forms.com/submit" method="POST" enctype="multipart/form-data">
              <input type="hidden" name="access_key" value={inquiryKey} />
              <input type="hidden" name="subject" value={`New inquiry — ${branch.foundation}, ${branch.name} [upcoming] (stjohnbiocare.com)`} />
              <input type="hidden" name="from_name" value="St. John Biocare — Center inquiry" />
              <input type="hidden" name="redirect" value="https://stjohnbiocare.com/thank-you/" />
              <input type="hidden" name="Center" value={`${branch.foundation} — ${branch.name} (upcoming)`} />
              <input type="hidden" name="Handled by" value={`${inquiryBranch.foundation} — ${inquiryBranch.name}`} />
              <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off" />
              <div class="grid grid--2" style="gap:0 18px">
                <div class="form-field">
                  <label for="mc-name">Your name</label>
                  <input id="mc-name" name="Name" type="text" required autocomplete="name" />
                </div>
                <div class="form-field">
                  <label for="mc-contact">Phone or email</label>
                  <input id="mc-contact" name="Contact (phone or email)" type="text" required />
                </div>
              </div>
              <div class="form-field">
                <label for="mc-msg">Your message</label>
                <textarea id="mc-msg" name="Message" required placeholder={`Ask about ${branch.name} — opening date, schedules, requirements…`}></textarea>
              </div>
              <label class="consent">
                <input type="checkbox" name="Consent (Data Privacy Act)" required />
                <span>I agree that St. John Biocare may contact me about my message and handle my
                information in line with the Data Privacy Act of 2012 (RA&nbsp;10173).</span>
              </label>
              <div style="margin-top:18px">
                <button type="submit" class="btn btn--crimson">Send message</button>
              </div>
              <p class="muted" style="font-size:.82rem;margin-top:12px">
                Not for emergencies. For urgent concerns, call the center or the nearest hospital ER.
              </p>
            </form>
          )}
        </div>
      </section>
    )}
    </>
  )}

  <script is:inline>
    // Phone lines are attended Mon–Sat, 5:30 AM – 5:00 PM (Asia/Manila).
    // Outside that window we hide the "Call the center" button and show a warm
    // notice pointing to the message form, so nobody is left ringing a dead line.
    (function () {
      var notice = document.querySelector('[data-oh-notice]');
      if (!notice) return;
      var call = document.querySelector('[data-oh-call]');

      // Preview override for testing at any hour:
      //   ?after-hours=1  → force the evening notice on
      //   ?after-hours=0  → force the daytime "Call the center" state
      var force = new URLSearchParams(location.search).get('after-hours');

      function attended() {
        if (force === '1') return false;
        if (force === '0') return true;
        var now = new Date(
          new Date().toLocaleString('en-US', { timeZone: 'Asia/Manila' })
        );
        var day = now.getDay();               // 0 = Sunday
        var mins = now.getHours() * 60 + now.getMinutes();
        var open = 5 * 60 + 30;               // 5:30 AM
        var close = 17 * 60;                  // 5:00 PM
        return day !== 0 && mins >= open && mins < close;
      }

      function update() {
        var isAttended = attended();
        notice.hidden = isAttended;
        if (call) call.hidden = !isAttended;
      }

      update();
      setInterval(update, 60000);
    })();
  </script>

  {!uc && (
    <>
  <!-- BUSINESS CARD -->
  <section class="section" style="padding-top:34px;padding-bottom:0">
    <div class="container" style="max-width:860px">
      <div class="bizcard">
        <div class="bizcard__body">
          <div class="bizcard__id">
            {foundationLogo && <img class="bizcard__logo" src={foundationLogo} alt={`${branch.foundation} logo`} width="72" height="72" loading="lazy" />}
            <div>
              <p class="eyebrow" style="margin:0 0 2px">{branch.foundation}</p>
              <h2 class="bizcard__name">{branch.name}</h2>
            </div>
          </div>
          <dl class="bizcard__rows">
            <div>
              <dt>Address</dt>
              <dd>{branch.address} · <a href={directions} target="_blank" rel="noopener">View map</a></dd>
            </div>
            <div>
              <dt>Phone</dt>
              <dd><a href={branch.phoneHref}>{branch.phone}</a></dd>
            </div>
            {branch.email && (
              <div>
                <dt>Email</dt>
                <dd><a href={`mailto:${branch.email}`}>{branch.email}</a></dd>
              </div>
            )}
            <div>
              <dt>Hours</dt>
              <dd>{branch.hours}<br /><span class="muted" style="font-size:.8rem">Also open on public holidays unless otherwise arranged.</span></dd>
            </div>
          </dl>
        </div>
        <div class="bizcard__qr">
          <div class="qr" set:html={qrSvg}></div>
          <a class="btn btn--primary bizcard__save" href={vcardHref} download={`${branch.slug}.vcf`}>Save to contacts</a>
          <p class="muted" style="font-size:.78rem;margin:8px 0 0">Scan the code — or tap Save.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container branch">
      <div class="branch__main stack">
        <div class="map-frame">
          <iframe
            src={mapSrc}
            title={`Map to ${branch.name}`}
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            style="border:0;width:100%;height:100%"></iframe>
        </div>

        <div class="card">
          <h2 style="font-size:1.4rem">On-site services</h2>
          <ul style="margin:0;padding-left:1.1rem;line-height:1.9">
            {branch.services.map((s) => <li>{s}</li>)}
          </ul>
        </div>

        <div class="card">
          <h2 style="font-size:1.4rem">Getting here</h2>
          <p>{branch.transit}</p>
          <p style="margin:0"><strong>Directions:</strong>
            <a href={directions} target="_blank" rel="noopener">Google Maps</a> ·
            <a href={waze} target="_blank" rel="noopener">Waze</a>
          </p>
        </div>
      </div>

      <aside class="branch__side stack">
        {centerKey && (
          <div class="card ahcard" data-oh-notice hidden>
            <p class="ahcard__eyebrow">After 5:00 PM</p>
            <p class="ahcard__text">
              <strong>Trying to reach us after 5:00&nbsp;PM?</strong> Our phone lines rest for the evening —
              send us a message and we'll get back to you first thing in the morning.
            </p>
            <a class="btn btn--crimson ahcard__cta" href="#message">
              <span aria-hidden="true">✉</span> Send us a message
            </a>
          </div>
        )}

        {hospitalList.length > 0 && (
          <div class="card">
            <h3 class="hospcare__title">If you ever need hospital care</h3>
            {hasMoa ? (
              <p class="hospcare__lead">This center works under formal agreements with partner hospitals nearby,
              so admission, emergency transfer, or specialist care can be arranged quickly — without you starting
              from scratch.</p>
            ) : (
              <p class="hospcare__lead">These are the hospitals nearest this center, and where our own
              nephrologists admit and consult. A formal partnership agreement is being arranged.</p>
            )}
            <ul class="hospitals">
              {hospitalList.map((h) => (
                <li class="hospitals__item">
                  <strong class="hospitals__name">{h.name}</strong>
                  {h.area && <span class="hospitals__area">{h.area}</span>}
                  <div class="hospitals__meta">
                    {hasMoa
                      ? h.covers && <span class="hospitals__covers">{h.covers}</span>
                      : <span class="hospitals__nearby">Nearby hospital</span>}
                    <a
                      class="hospitals__map"
                      href={h.map ?? `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(h.name)}`}
                      target="_blank"
                      rel="noopener">View map</a>
                  </div>
                </li>
              ))}
            </ul>
            {!hasMoa && (
              <p class="hospcare__pending">Listed for convenience only — we don't yet have a formal agreement
              with these hospitals. Our team will still help you coordinate if you need to be admitted.</p>
            )}
          </div>
        )}

        <div class="card">
          <h3>Care team</h3>
          <p style="margin:0 0 .3rem"><strong>Medical Director:</strong> {branch.medicalDirector}</p>
          <p style="margin:0 0 .3rem"><strong>Head Nurse:</strong> {branch.headNurse}</p>
          {branch.stations && <p style="margin:0"><strong>Dialysis stations:</strong> {branch.stations}</p>}
        </div>

        {branch.affiliatedNephrologists && branch.affiliatedNephrologists.length > 0 && (
          <div class="card">
            <h3>Affiliated nephrologists</h3>
            <ul class="docs">
              {branch.affiliatedNephrologists.map((d) => (
                <li class="docs__item">
                  <strong class="docs__name">{d.name}</strong>
                  {d.hospitals && d.hospitals.map((h) => (
                    <div class="docs__hosp">
                      <span class="docs__hospname">{h.name}</span>
                      <a
                        class="docs__map"
                        href={h.map ?? `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(h.name)}`}
                        target="_blank"
                        rel="noopener">View map</a>
                    </div>
                  ))}
                </li>
              ))}
            </ul>
          </div>
        )}
      </aside>
    </div>
  </section>

  {centerKey && (
    <section id="message" class="section section--sand">
      <div class="container" style="max-width:640px">
        <div class="center" style="margin-bottom:20px">
          <p class="eyebrow">Message this center</p>
          <h2>Send {branch.name} a message.</h2>
          <p class="muted">Your message goes <strong>straight to the {branch.name} team</strong>. For a full
          appointment request, use the <a href="/new-patients#request">appointment form</a>.</p>
        </div>
        <form class="card" action="https://api.web3forms.com/submit" method="POST" enctype="multipart/form-data">
          <input type="hidden" name="access_key" value={centerKey} />
          <input type="hidden" name="subject" value={`New message — ${branch.foundation}, ${branch.name} (stjohnbiocare.com)`} />
          <input type="hidden" name="from_name" value="St. John Biocare — Center message" />
          <input type="hidden" name="redirect" value="https://stjohnbiocare.com/thank-you/" />
          <input type="hidden" name="Center" value={`${branch.foundation} — ${branch.name}`} />
          <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off" />
          <div class="grid grid--2" style="gap:0 18px">
            <div class="form-field">
              <label for="mc-name">Your name</label>
              <input id="mc-name" name="Name" type="text" required autocomplete="name" />
            </div>
            <div class="form-field">
              <label for="mc-contact">Phone or email</label>
              <input id="mc-contact" name="Contact (phone or email)" type="text" required />
            </div>
          </div>
          <div class="form-field">
            <label for="mc-msg">Your message</label>
            <textarea id="mc-msg" name="Message" required placeholder={`Ask ${branch.name} anything — schedules, requirements, coverage…`}></textarea>
          </div>
          <div class="form-field">
            <label for="mc-file">Attach a file <span class="muted" style="font-weight:400">(optional)</span></label>
            <input id="mc-file" name="attachment" type="file" accept="image/*,application/pdf,.doc,.docx" />
            <p class="muted" style="font-size:.82rem;margin:.3rem 0 0">
              Optional — e.g. a photo of your lab results, referral or PhilHealth MDR (JPG, PNG or PDF).
            </p>
          </div>
          <label class="consent">
            <input type="checkbox" name="Consent (Data Privacy Act)" required />
            <span>I agree that St. John Biocare may contact me about my message and handle my information in
            line with the Data Privacy Act of 2012 (RA&nbsp;10173).</span>
          </label>
          <div style="margin-top:18px">
            <button type="submit" class="btn btn--crimson">Send message</button>
          </div>
          <p class="muted" style="font-size:.82rem;margin-top:12px">
            Not for emergencies. For urgent concerns, call the center or the nearest hospital ER.
          </p>
        </form>
      </div>
    </section>
  )}

  <section class="section section--forest center">
    <div class="container" style="max-width:640px">
      <h2>Ready to visit {branch.name}?</h2>
      <p style="color:#e5f3e9">Send a short request and our team will get back to you.</p>
      <a href="/new-patients#request" class="btn btn--light" style="margin-top:8px">Request an appointment</a>
    </div>
  </section>
    </>
  )}
</BaseLayout>

<style>
  .serving-badge {
    display: inline-flex; align-items: center; gap: 8px; flex-wrap: wrap;
    margin: 14px 0 0; padding: 8px 16px; border-radius: 999px;
    background: color-mix(in srgb, var(--life) 12%, #fff);
    border: 1px solid color-mix(in srgb, var(--life) 32%, transparent);
    color: var(--forest); font-weight: 600; font-size: 1rem; line-height: 1.2;
  }
  .serving-badge strong { color: var(--life); font-weight: 800; }
  .serving-since { color: var(--ink-soft); font-weight: 600; }

  /* AFTER-HOURS CARD — sidebar card, appears automatically once the phone lines
     close (5:00 PM, Asia/Manila). Sand fill so it reads as a gentle aside. */
  .ahcard { background: var(--sand); }
  .ahcard[hidden] { display: none; }
  .ahcard__eyebrow {
    margin: 0 0 6px; font-size: .7rem; font-weight: 700; letter-spacing: .09em;
    text-transform: uppercase; color: var(--ink-soft);
  }
  .ahcard__text { margin: 0 0 14px; color: var(--ink); line-height: 1.55; font-size: .95rem; }
  .ahcard__text strong { color: var(--crimson); }
  .ahcard__cta { display: inline-flex; align-items: center; gap: 8px; }

  /* PARTNER HOSPITALS (MOA) — sidebar card; rows stack in the narrow column. */
  .hospcare__title { color: var(--crimson); }
  .hospcare__lead { margin: 0 0 14px; color: var(--ink-soft); line-height: 1.55; font-size: .92rem; }

  .hospitals { list-style: none; margin: 0; padding: 0; display: grid; gap: 10px; }
  .hospitals__item {
    display: grid; gap: 4px; justify-items: start;
    padding: 13px 15px; border: 1px solid var(--border); border-radius: 12px; background: #fff;
  }
  .hospitals__name { font-size: 1rem; color: var(--ink); font-weight: 600; line-height: 1.3; }
  .hospitals__area { font-size: .86rem; color: var(--ink-soft); }
  .hospitals__meta { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; margin-top: 4px; }
  .hospitals__covers {
    white-space: nowrap; font-size: .75rem; font-weight: 700;
    padding: 5px 11px; border-radius: 999px;
    background: color-mix(in srgb, var(--life) 15%, #fff); color: var(--forest);
  }
  .hospitals__map { font-weight: 700; text-decoration: none; white-space: nowrap; font-size: .86rem; }
  /* Neutral pill for hospitals with no signed MOA — visually distinct from the green
     "covered" pill so the two can never be mistaken for each other. */
  .hospitals__nearby {
    white-space: nowrap; font-size: .75rem; font-weight: 700;
    padding: 5px 11px; border-radius: 999px;
    background: #F1EFE8; color: #5F5E5A;
  }
  .hospcare__pending {
    margin: 12px 0 0; font-size: .8rem; line-height: 1.5; color: var(--ink-soft);
    padding-top: 10px; border-top: 1px solid var(--border);
  }

  /* Affiliated nephrologists — name, then hospital affiliation, then its map link. */
  .docs { list-style: none; margin: 0; padding: 0; display: grid; gap: 16px; }
  .docs__item { display: grid; gap: 4px; }
  .docs__name { font-size: 1rem; color: var(--ink); font-weight: 600; line-height: 1.3; }
  .docs__hosp {
    display: flex; align-items: baseline; gap: 8px; flex-wrap: wrap;
    font-size: .86rem; line-height: 1.45;
  }
  .docs__hospname { color: var(--ink-soft); }
  .docs__map { font-weight: 700; text-decoration: none; white-space: nowrap; }

  .branch { display: grid; grid-template-columns: 1.6fr .9fr; gap: 26px; align-items: start; }
  @media (max-width: 860px) { .branch { grid-template-columns: 1fr; } }
  .map-frame { border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow); height: 340px; background: var(--sand); }
  .branch h3 { font-size: 1.15rem; margin-bottom: .4rem; }
  .qr svg { width: 100%; height: auto; display: block; }

  .bizcard {
    display: grid; grid-template-columns: 1fr auto; gap: 32px; align-items: center;
    padding: 30px 32px; border-radius: 20px; border: 1px solid var(--border);
    border-top: 5px solid var(--forest); box-shadow: var(--shadow);
    background: linear-gradient(135deg, #ffffff, var(--mist));
