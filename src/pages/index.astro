---
import BaseLayout from '../layouts/BaseLayout.astro';
import BiocareValues from '../components/BiocareValues.astro';
import { openBranches } from '../data/branches';
import { site } from '../data/site';

const services = [
  { title: 'Every dialysis modality', text: 'Low- and high-flux HD, hemodiafiltration, SLED and isolated ultrafiltration — matched to your body, never a default.', href: '/services#treatment', icon: '🩺' },
  { title: 'A doctor always on duty', text: "In the room every hour we're open — not on call down the hall — watching over your treatment.", href: '/services#team', icon: '👨‍⚕️' },
  { title: 'Renal dietitians', text: 'A kidney diet built around Filipino food and your own table — advice you can actually keep.', href: '/services#team', icon: '🥗' },
  { title: 'Social workers', text: 'PhilHealth, the paperwork, the money worries — carried with you, so you carry less.', href: '/services#team', icon: '🤝' },
  { title: 'Lab coordination', text: 'Bloodwork coordinated with trusted partner laboratories — reliable results, on time, without the runaround.', href: '/services', icon: '🧪' },
  { title: 'Care explained plainly', text: 'We put kidney health in plain language, so you and your family always understand what happens next.', href: '/kidney-health', icon: '📖' },
];

const safety = [
  { title: 'Well-established medicines', text: 'Your erythropoietin, IV iron and Halal-certified heparin come from well-established, proven brands — quality we stand behind, not the cheapest option for its own sake.' },
  { title: 'Water purified twice', text: 'Every center runs dual-pass reverse-osmosis, cleansing the water twice over before a single drop reaches a machine.' },
  { title: 'Maker-calibrated machines', text: 'Established brands, calibrated by no one but the original manufacturers, on a regular schedule.' },
  { title: 'International best practice', text: "We don't just meet Philippine standards — wherever a higher bar exists, that's the one we hold ourselves to." },
  { title: 'Infection control by protocol', text: 'Disciplined, protocol-driven reprocessing and formal infection-control practices govern every single session.' },
  { title: 'Sundays, we work hardest', text: 'Closed to patients for wall-to-wall disinfection and full servicing of the water system. You return Monday to a center checked top to bottom.' },
];
---
<BaseLayout image="/images/og/og-home.jpg">
  <!-- 1. HERO (full-bleed) -->
  <section class="page-hero home-hero">
    <img class="page-hero__img" src="/images/heroes/home-hero.webp"
         alt="A St. John Biocare nurse and an adult daughter comforting an older patient resting during a hemodialysis session"
         width="1536" height="1024" fetchpriority="high" loading="eager" style="object-position:center" />
    <div class="page-hero__scrim"></div>
    <div class="container page-hero__inner">
      <span class="pill" style="margin-bottom:16px">A foundation, not a chain · Pioneering dialysis since 2011</span>
      <h1><span class="hl" style="color:#ff8ba0">Excellent</span> dialysis, for every family — not just a few.</h1>
      <p class="lead">
        We're a family-run foundation, not a corporate chain — and it shows most in the parts
        you can't see. Three times a week, for years, you place your life in our hands. We built
        every center to be worthy of that: warm enough to feel like family, honest about every
        peso, and relentless about the safety no patient should have to think about.
      </p>
      <div class="page-hero__actions">
        <a href="/new-patients#request" class="btn btn--crimson">Request an appointment</a>
        <a href="/centers" class="btn btn--light">Find a center near you</a>
      </div>
    </div>
  </section>

  <!-- 2. REASSURANCE STRIP -->
  <section class="reassure">
    <div class="container reassure__grid">
      <div><strong>15 years</strong><span>among the country's dialysis pioneers</span></div>
      <div><strong>{openBranches.length} centers</strong><span>and growing, across Metro Manila &amp; Bulacan</span></div>
      <div><strong>Open 5:30&nbsp;AM</strong><span>dialyze before work, Monday to Saturday</span></div>
      <div><strong>PhilHealth &amp; HMO</strong><span>we help you make sense of every peso</span></div>
    </div>
  </section>

  <!-- 3. WHY WE EXIST -->
  <section class="section">
    <div class="container" style="max-width:820px;text-align:center">
      <p class="eyebrow">Why we exist</p>
      <h2>It started with a son, a mother, and a refusal to settle.</h2>
      <p class="lead" style="margin-inline:auto">
        St. John Biocare began when our founder walked his mother through kidney failure and
        dialysis — and saw two things at once: how truly <strong>life-saving</strong> good care can
        be, and how far the care and the cost at existing centers fell short of what families
        deserve. He refused to accept it. With a lifelong friend, he set out to build dialysis that
        families could trust and afford. We were built as a <strong>foundation</strong>, which means
        putting the patient first isn't a slogan here. It's who we answer to. Fifteen years on, we
        stand among the <strong>pioneers of free-standing dialysis care in the Philippines</strong> —
        and the promise that started it all has never wavered.
      </p>
      <p><a href="/about" class="btn btn--ghost" style="margin-top:8px">Read our story</a></p>
    </div>
  </section>

  <!-- 4. WHAT WE OFFER -->
  <section class="section section--sand">
    <div class="container">
      <div class="center" style="margin-bottom:32px">
        <p class="eyebrow">Complete care</p>
        <h2>Everything your dialysis needs — nothing you have to chase.</h2>
        <p class="lead" style="margin-inline:auto">One team, one place, every part of your care thought through — so all you have to do is show up and get well.</p>
      </div>
      <div class="grid grid--3">
        {services.map((s) => (
          <a class="card" href={s.href} style="text-decoration:none;color:inherit;display:block">
            <div class="card__icon" style="font-size:1.5rem">{s.icon}</div>
            <h3>{s.title}</h3>
            <p>{s.text}</p>
            <span class="card__link">Learn more</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 5. HOW WELL WE DO IT — QUALITY & SAFETY -->
  <section class="section qs">
    <div class="container">
      <div style="max-width:720px">
        <p class="eyebrow" style="color:#e6c374">Quality &amp; safety</p>
        <h2 style="color:#fff">The safety you can't see is the safety that matters most.</h2>
        <p style="color:#cfe6d6;font-size:1.1rem;max-width:62ch">
          Anyone can put a chair and a machine in a room. What actually keeps you safe happens where
          you never look — the medicines, the water, the calibration, the cleaning. We built our name
          on refusing to cut those corners.
        </p>
      </div>
      <div class="qs__grid">
        {safety.map((s) => (
          <div class="qs__card">
            <h3>{s.title}</h3>
            <p>{s.text}</p>
          </div>
        ))}
      </div>
      <div style="margin-top:26px">
        <a href="/services" class="btn btn--light">See how we care for you</a>
      </div>
    </div>
  </section>

  <!-- 6. WHO WE ARE — BIOCARE PROMISE -->
  <section class="section section--mist">
    <div class="container">
      <div class="center" style="margin-bottom:32px">
        <p class="eyebrow">Our promise</p>
        <h2>The BIOCARE way.</h2>
        <p class="lead" style="margin-inline:auto">Seven values, one for each letter — the promises we keep even when no one is watching.</p>
      </div>
      <BiocareValues />
    </div>
  </section>

  <!-- 7. WHAT FAMILIES SAY -->
  <section class="section section--sand">
    <div class="container center" style="max-width:760px">
      <p class="eyebrow">Patient &amp; family voices</p>
      <div class="voices" data-voices>
        <div class="voices__stage">
          <blockquote class="voices__slide is-active">
            <p class="quote">“They explained everything to my mother in words she understood, and never made us feel rushed. For the first time, dialysis didn't feel frightening.”</p>
            <p class="muted">— A family member, Quezon City</p>
          </blockquote>
          <blockquote class="voices__slide">
            <p class="quote">“The staff are nice, helpful, respectful, and caring to all patients. We appreciate the clean center, the pleasant environment, and the family-like relationship we've built here. Keep it up and continue doing your best.”</p>
            <p class="muted">— Patients of St. Josef Renal Care – Concepcion</p>
          </blockquote>
          <blockquote class="voices__slide">
            <p class="quote">“The staff are friendly, professional, and caring — they take good care of the patients and are very attentive to their needs. The equipment is well-maintained, the service is fast, and the environment is comfortable and relaxing. I like how everyone is helpful, especially for those of us who are new to dialysis. The nurses and staff treat you like family and always consider your needs. As one patient shared: even in my first month, my dialysis three times a week has gone well, the nurses are wonderful to be with, and I'm truly grateful for how they care for my spouse. We're glad we chose this center — keep up the good work!”</p>
            <p class="muted">— Patients of St. John Biocare – Marikina</p>
          </blockquote>
          <blockquote class="voices__slide">
            <p class="quote">“Very accommodating with quality service. I like all the staff — they're hardworking, very friendly, professional, and God-fearing people. The doctors and nurses are truly caring and attentive; they're the reason I won't transfer to another provider even though I'm from Bulacan. Overall, everything is okay and I have nothing to suggest — just continue your good work.”</p>
            <p class="muted">— Patients of St. John Biocare – Caloocan</p>
          </blockquote>
          <blockquote class="voices__slide">
            <p class="quote">“All of the staff are friendly, nice, and caring. The nurses especially help, assist, and treat patients with care, compassion, and empathy. A clean facility with good nurses.”</p>
            <p class="muted">— Patients of St. Josef Renal Care – Marilao</p>
          </blockquote>
          <blockquote class="voices__slide">
            <p class="quote">“On the whole, we appreciate the friendly atmosphere among the staff, patients, and relatives — the doctors, nurses, and admin staff are all professional. The culture and environment are good, and the nurses especially deserve a round of applause. I like that the staff are friendly and easy to get along with; they're always smiling, so you never feel shy about asking questions or talking to them. Thank you, Core!”</p>
            <p class="muted">— Patients of Core Renal Center – Santillan</p>
          </blockquote>
        </div>
        <div class="voices__dots" aria-label="Patient voices">
          <button class="voices__dot is-active" type="button" aria-label="Voice 1"></button>
          <button class="voices__dot" type="button" aria-label="Voice 2"></button>
          <button class="voices__dot" type="button" aria-label="Voice 3"></button>
          <button class="voices__dot" type="button" aria-label="Voice 4"></button>
          <button class="voices__dot" type="button" aria-label="Voice 5"></button>
          <button class="voices__dot" type="button" aria-label="Voice 6"></button>
        </div>
      </div>
    </div>
  </section>

  <!-- 8. WHERE — FIND YOUR CENTER -->
  <section class="section">
    <div class="container">
      <div class="center" style="margin-bottom:32px">
        <p class="eyebrow">Our centers</p>
        <h2>Find the center nearest you.</h2>
        <p class="lead" style="margin-inline:auto">A growing network across Metro Manila and Bulacan — each center open six days a week, early enough to finish dialysis and still make it to work.</p>
      </div>
      <div class="grid grid--3">
        {openBranches.map((b) => (
          <a class="card" href={`/centers/${b.slug}`} style="text-decoration:none;color:inherit;display:block">
            <span class="pill" style="margin-bottom:10px">{b.area}</span>
            <p class="eyebrow" style="margin:0 0 2px">{b.foundation}</p>
            <h3>{b.name}</h3>
            <p>{b.hours}</p>
            <span class="card__link">View this center</span>
          </a>
        ))}
      </div>
      <div class="center" style="margin-top:26px">
        <a href="/centers" class="btn btn--primary">See all centers &amp; map</a>
      </div>
    </div>
  </section>

  <!-- 9. WHAT IT COSTS -->
  <section class="section section--mist">
    <div class="container cost">
      <div>
        <p class="eyebrow">Honest about cost</p>
        <h2>The question everyone's afraid to ask: how much will this cost?</h2>
        <p class="lead">
          Most centers would rather not talk about money. We start there — walking you
          through your PhilHealth coverage, what the case rates really mean, and what to
          expect, in plain language, before you commit to anything.
        </p>
        <a href="/kidney-health/philhealth-cost" class="btn btn--primary">PhilHealth &amp; cost, explained</a>
      </div>
      <div class="cost__card notice">
        <strong>Good to know</strong>
        <p style="margin-top:.4rem">
          PhilHealth provides dialysis coverage for eligible members — and we're also
          <strong>HMO-accredited</strong> and accept <strong>various forms of payment</strong>.
          Bring your PhilHealth MDR or HMO card and we'll help you check what applies to you.
        </p>
      </div>
    </div>
  </section>

  <!-- 10. LEARN — KIDNEY HEALTH TEASER -->
  <section class="section">
    <div class="container">
      <div class="center" style="margin-bottom:32px">
        <p class="eyebrow">Kidney Health Hub</p>
        <h2>Understand your kidneys, in plain Filipino-English.</h2>
        <p class="lead" style="margin-inline:auto">Free, honest guides — because a patient who understands what's happening is a patient who does better.</p>
      </div>
      <div class="grid grid--3">
        <a class="card" href="/kidney-health/understanding-kidney-disease" style="text-decoration:none;color:inherit">
          <h3>Understanding kidney disease &amp; ESRD</h3>
          <p>What happens to the kidneys, and what dialysis actually does.</p>
          <span class="card__link">Read</span>
        </a>
        <a class="card" href="/kidney-health/starting-dialysis" style="text-decoration:none;color:inherit">
          <h3>Starting dialysis: what to expect</h3>
          <p>Your first sessions, step by step, with the fear taken out.</p>
          <span class="card__link">Read</span>
        </a>
        <a class="card" href="/kidney-health/philhealth-cost" style="text-decoration:none;color:inherit">
          <h3>PhilHealth &amp; the cost of dialysis</h3>
          <p>The most-searched, least-answered question — answered honestly.</p>
          <span class="card__link">Read</span>
        </a>
      </div>
    </div>
  </section>

  <!-- 11. FOR NURSES -->
  <section class="section section--forest">
    <div class="container nurses">
      <div>
        <p class="eyebrow">For nurses</p>
        <h2>We train the nurses others hire.</h2>
        <p style="color:#e5f3e9;font-size:1.15rem;max-width:52ch">
          Our Hemodialysis Nurse Training Program builds renal nursing skill from the
          ground up — and many of our graduates go on to join the family. Real mentorship,
          strong benefits, and a career that means something.
        </p>
      </div>
      <div class="nurses__actions">
        <a href="/training-academy" class="btn btn--light">Training Academy</a>
        <a href="/careers" class="btn btn--crimson">See open roles</a>
      </div>
    </div>
  </section>

  <!-- 12. ACT — FINAL CTA -->
  <section class="section center">
    <div class="container" style="max-width:680px">
      <h2>Take the first step. We'll take it with you.</h2>
      <p class="lead" style="margin-inline:auto">
        Call, message, or send a short request — a real person answers, and helps you work out
        what's next. No pressure. No runaround. Just a straight answer from someone who cares.
      </p>
      <div class="hero__actions" style="justify-content:center">
        <a href={site.phoneHref} class="btn btn--primary">Call {site.phone}</a>
        <a href="/new-patients#request" class="btn btn--ghost">Send a request</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero { background: linear-gradient(180deg, var(--mist), var(--cream)); overflow: hidden; }
  .hero__inner { display: grid; grid-template-columns: 1.15fr .85fr; gap: 40px; align-items: center; padding-block: clamp(40px, 7vw, 84px); }
  .hero__copy .pill { margin-bottom: 18px; }
  .hero h1 { margin-top: 6px; }
  .hero h1 .hl { color: var(--crimson); }
  .hero__actions { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 26px; }
  .hero__art { display: grid; place-items: center; }
  .hero__heart { width: min(380px, 82%); filter: drop-shadow(0 18px 38px rgba(0,60,30,.18)); animation: floaty 6s ease-in-out infinite; }
  .hero__heart img { width: 100%; height: auto; display: block; }
  @keyframes floaty { 0%,100% { transform: translateY(0) } 50% { transform: translateY(-12px) } }
  @media (max-width: 860px) { .hero__inner { grid-template-columns: 1fr; } .hero__art { order: -1; } .hero__heart { width: 200px; } }

  .qs { background: var(--forest); }
  .qs__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: rgba(255,255,255,.16); border: 1px solid rgba(255,255,255,.16); border-radius: 16px; overflow: hidden; margin-top: 28px; }
  .qs__card { background: var(--forest); padding: 28px 26px; }
  .qs__card h3 { color: #fff; font-family: var(--font-head); font-size: 1.15rem; margin: 0 0 .5rem; }
  .qs__card p { color: #cfe6d6; margin: 0; line-height: 1.55; }
  @media (max-width: 820px) { .qs__grid { grid-template-columns: 1fr; } }

  .reassure { background: var(--forest); color: var(--cream); }
  .reassure__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; padding-block: 26px; text-align: center; }
  .reassure__grid div { display: flex; flex-direction: column; }
  .reassure__grid strong { font-family: var(--font-head); font-size: 1.4rem; color: #fff; }
  .reassure__grid span { color: #cfe6d6; font-size: .95rem; }
  @media (max-width: 900px) { .reassure__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 520px) { .reassure__grid { grid-template-columns: 1fr; gap: 12px; } }

  .cost { display: grid; grid-template-columns: 1.3fr .7fr; gap: 34px; align-items: center; }
  @media (max-width: 820px) { .cost { grid-template-columns: 1fr; } }

  .quote { font-family: var(--font-head); font-size: clamp(1.3rem, 3vw, 1.9rem); color: var(--forest); line-height: 1.4; margin: 10px 0 14px; }

  .nurses { display: grid; grid-template-columns: 1.4fr .6fr; gap: 30px; align-items: center; }
  .nurses__actions { display: flex; flex-direction: column; gap: 12px; }
  @media (max-width: 820px) { .nurses { grid-template-columns: 1fr; } .nurses__actions { flex-direction: row; flex-wrap: wrap; } }

  /* Patient & family voices — fade-to-next auto-rotating testimonials. */
  .voices__stage { display: grid; margin-top: 6px; }
  .voices__slide { grid-area: 1 / 1; margin: 0; display: flex; flex-direction: column; justify-content: center;
    opacity: 0; pointer-events: none; transition: opacity .7s ease; }
  .voices__slide.is-active { opacity: 1; pointer-events: auto; }
  .voices__slide .quote { font-size: clamp(1.1rem, 2.3vw, 1.5rem); line-height: 1.5; margin: 0 0 14px; }
  .voices__dots { display: flex; gap: 9px; justify-content: center; margin-top: 24px; }
  .voices__dot { width: 9px; height: 9px; padding: 0; border: none; border-radius: 50%; cursor: pointer;
    background: color-mix(in srgb, var(--forest) 24%, transparent); transition: background .2s, transform .2s; }
  .voices__dot.is-active { background: var(--forest); transform: scale(1.25); }
  @media (prefers-reduced-motion: reduce) { .voices__slide { transition: none; } }
</style>

<script>
  function initVoices() {
    const root = document.querySelector('[data-voices]');
    if (!root) return;
    const slides = Array.from(root.querySelectorAll('.voices__slide'));
    const dots = Array.from(root.querySelectorAll('.voices__dot'));
    if (slides.length < 2) return;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let i = Math.max(0, slides.findIndex((s) => s.classList.contains('is-active')));
    let timer = null;
    function show(n) {
      i = (n + slides.length) % slides.length;
      slides.forEach((s, k) => { const a = k === i; s.classList.toggle('is-active', a); s.setAttribute('aria-hidden', String(!a)); });
      dots.forEach((d, k) => d.classList.toggle('is-active', k === i));
    }
    function start() { if (reduce) return; stop(); timer = window.setInterval(() => show(i + 1), 7000); }
    function stop() { if (timer) { window.clearInterval(timer); timer = null; } }
    dots.forEach((d, k) => d.addEventListener('click', () => { show(k); start(); }));
    root.addEventListener('mouseenter', stop);
    root.addEventListener('mouseleave', start);
    root.addEventListener('focusin', stop);
    root.addEventListener('focusout', start);
    show(i); start();
  }
  initVoices();
  document.addEventListener('astro:page-load', initVoices);
</script>
