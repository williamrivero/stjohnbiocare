---
import BaseLayout from '../layouts/BaseLayout.astro';
import BiocareValues from '../components/BiocareValues.astro';
import { openBranches } from '../data/branches';
import { site } from '../data/site';

const services = [
  { title: 'Hemodialysis', text: 'Modern machines, watchful nurses, and 5:30 AM chairs — so you can dialyze and still make a day of work.', href: '/services#hemodialysis', icon: '🩺' },
  { title: 'Physicians on duty', text: "A doctor here every hour we're open — not on call down the hall, but in the room, watching over you.", href: '/services#physicians', icon: '👨‍⚕️' },
  { title: 'Renal dietitians', text: 'A kidney diet built around Filipino food and your own table — advice you can actually keep.', href: '/services#dietitian', icon: '🥗' },
  { title: 'Social workers', text: 'PhilHealth, the paperwork, the money worries — carried with you, so you carry less.', href: '/services#social', icon: '🤝' },
];
---
<BaseLayout image="/images/og/og-home.jpg">
  <!-- 1. HERO (full-bleed) -->
  <section class="page-hero home-hero">
    <img class="page-hero__img" src="/images/photos/dsc_0053.webp"
         alt="A patient resting comfortably during a hemodialysis session at St. John Biocare"
         width="2000" height="1328" fetchpriority="high" loading="eager" style="object-position:center" />
    <div class="page-hero__scrim"></div>
    <div class="container page-hero__inner">
      <span class="pill" style="margin-bottom:16px">A foundation, not a chain · Since 2011</span>
      <h1><span class="hl" style="color:#ff8ba0">Excellent</span> dialysis, for every family — not just a few.</h1>
      <p class="lead">
        We're a family-run foundation, not a corporate chain — and it shows most in the parts
        you can't see. Three times a week, for years, you place your life in our hands. We built
        every center to be worthy of that: warm enough to feel like family, honest about every
        peso, and relentless about the safety no patient should have to think about.
      </p>
      <div class="page-hero__actions">
        <a href="/new-patients#request" class="btn btn--crimson">Request an appointment</a>
        <a href="/centers" class="btn btn--light">Find a center near you</a>
      </div>
    </div>
  </section>

  <!-- 2. REASSURANCE STRIP -->
  <section class="reassure">
    <div class="container reassure__grid">
      <div><strong>{openBranches.length} centers</strong><span>and growing, across Metro Manila &amp; Bulacan</span></div>
      <div><strong>Open 5:30&nbsp;AM</strong><span>dialyze before work, Monday to Saturday</span></div>
      <div><strong>PhilHealth &amp; HMO</strong><span>we help you make sense of every peso</span></div>
    </div>
  </section>

  <!-- 3. WHY WE EXIST -->
  <section class="section">
    <div class="container" style="max-width:820px;text-align:center">
      <p class="eyebrow">Why we exist</p>
      <h2>It started with a son, a mother, and a refusal to settle.</h2>
      <p class="lead" style="margin-inline:auto">
        St. John Biocare began when a son, walking his mother through end-stage renal disease,
        saw what truly excellent care can do — and refused to accept that dialysis had to feel
        as cold as what he found elsewhere. So he set out to prove it could be done better. We
        were built as a <strong>foundation</strong>, which means putting the patient first isn't
        a slogan here. It's who we answer to.
      </p>
      <p><a href="/about" class="btn btn--ghost" style="margin-top:8px">Read our story</a></p>
    </div>
  </section>

  <!-- 4. SERVICES AT A GLANCE -->
  <section class="section section--sand">
    <div class="container">
      <div class="center" style="margin-bottom:32px">
        <p class="eyebrow">Complete care</p>
        <h2>Everything your dialysis needs — nothing you have to chase.</h2>
        <p class="lead" style="margin-inline:auto">One team, one place, every part of your care thought through — so all you have to do is show up and get well.</p>
      </div>
      <div class="grid grid--4">
        {services.map((s) => (
          <a class="card" href={s.href} style="text-decoration:none;color:inherit;display:block">
            <div class="card__icon" style="font-size:1.5rem">{s.icon}</div>
            <h3>{s.title}</h3>
            <p>{s.text}</p>
            <span class="card__link">Learn more</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 5. FIND YOUR CENTER -->
  <section class="section">
    <div class="container">
      <div class="center" style="margin-bottom:32px">
        <p class="eyebrow">Our centers</p>
        <h2>Find the center nearest you.</h2>
        <p class="lead" style="margin-inline:auto">A growing network across Metro Manila and Bulacan — each center open six days a week, early enough to finish dialysis and still make it to work.</p>
      </div>
      <div class="grid grid--3">
        {openBranches.map((b) => (
          <a class="card" href={`/centers/${b.slug}`} style="text-decoration:none;color:inherit;display:block">
            <span class="pill" style="margin-bottom:10px">{b.area}</span>
            <p class="eyebrow" style="margin:0 0 2px">{b.foundation}</p>
            <h3>{b.name}</h3>
            <p>{b.hours}</p>
            <span class="card__link">View this center</span>
          </a>
        ))}
      </div>
      <div class="center" style="margin-top:26px">
        <a href="/centers" class="btn btn--primary">See all centers &amp; map</a>
      </div>
    </div>
  </section>

  <!-- 6. BIOCARE PROMISE -->
  <section class="section section--mist">
    <div class="container">
      <div class="center" style="margin-bottom:32px">
        <p class="eyebrow">Our promise</p>
        <h2>The BIOCARE way.</h2>
        <p class="lead" style="margin-inline:auto">Seven values, one for each letter — the promises we keep even when no one is watching.</p>
      </div>
      <BiocareValues />
    </div>
  </section>

  <!-- 7. COST & PHILHEALTH -->
  <section class="section">
    <div class="container cost">
      <div>
        <p class="eyebrow">Honest about cost</p>
        <h2>The question everyone's afraid to ask: how much will this cost?</h2>
        <p class="lead">
          Most centers would rather not talk about money. We start there — walking you
          through your PhilHealth coverage, what the case rates really mean, and what to
          expect, in plain language, before you commit to anything.
        </p>
        <a href="/kidney-health/philhealth-cost" class="btn btn--primary">PhilHealth &amp; cost, explained</a>
      </div>
      <div class="cost__card notice">
        <strong>Good to know</strong>
        <p style="margin-top:.4rem">
          PhilHealth provides dialysis coverage for eligible members — and we're also
          <strong>HMO-accredited</strong> and accept <strong>various forms of payment</strong>.
          Bring your PhilHealth MDR or HMO card and we'll help you check what applies to you.
        </p>
      </div>
    </div>
  </section>

  <!-- 8. VOICES (placeholder) -->
  <section class="section section--sand">
    <div class="container center" style="max-width:760px">
      <p class="eyebrow">Patient &amp; family voices</p>
      <blockquote class="quote">
        “They explained everything to my mother in words she understood, and never
        made us feel rushed. For the first time, dialysis didn't feel frightening.”
      </blockquote>
      <p class="muted">— A family member, Quezon City <em>(sample — real, consented quotes to be added)</em></p>
    </div>
  </section>

  <!-- 9. KIDNEY HEALTH TEASER -->
  <section class="section">
    <div class="container">
      <div class="center" style="margin-bottom:32px">
        <p class="eyebrow">Kidney Health Hub</p>
        <h2>Understand your kidneys, in plain Filipino-English.</h2>
        <p class="lead" style="margin-inline:auto">Free, honest guides — because a patient who understands what's happening is a patient who does better.</p>
      </div>
      <div class="grid grid--3">
        <a class="card" href="/kidney-health/understanding-kidney-disease" style="text-decoration:none;color:inherit">
          <h3>Understanding kidney disease &amp; ESRD</h3>
          <p>What happens to the kidneys, and what dialysis actually does.</p>
          <span class="card__link">Read</span>
        </a>
        <a class="card" href="/kidney-health/starting-dialysis" style="text-decoration:none;color:inherit">
          <h3>Starting dialysis: what to expect</h3>
          <p>Your first sessions, step by step, with the fear taken out.</p>
          <span class="card__link">Read</span>
        </a>
        <a class="card" href="/kidney-health/philhealth-cost" style="text-decoration:none;color:inherit">
          <h3>PhilHealth &amp; the cost of dialysis</h3>
          <p>The most-searched, least-answered question — answered honestly.</p>
          <span class="card__link">Read</span>
        </a>
      </div>
    </div>
  </section>

  <!-- 10. FOR NURSES -->
  <section class="section section--forest">
    <div class="container nurses">
      <div>
        <p class="eyebrow">For nurses</p>
        <h2>We train the nurses others hire.</h2>
        <p style="color:#e5f3e9;font-size:1.15rem;max-width:52ch">
          Our Hemodialysis Nurse Training Program builds renal nursing skill from the
          ground up — and many of our graduates go on to join the family. Real mentorship,
          strong benefits, and a career that means something.
        </p>
      </div>
      <div class="nurses__actions">
        <a href="/training-academy" class="btn btn--light">Training Academy</a>
        <a href="/careers" class="btn btn--crimson">See open roles</a>
      </div>
    </div>
  </section>

  <!-- 11. FINAL CTA -->
  <section class="section center">
    <div class="container" style="max-width:680px">
      <h2>Take the first step. We'll take it with you.</h2>
      <p class="lead" style="margin-inline:auto">
        Call, message, or send a short request — a real person answers, and helps you work out
        what's next. No pressure. No runaround. Just a straight answer from someone who cares.
      </p>
      <div class="hero__actions" style="justify-content:center">
        <a href={site.phoneHref} class="btn btn--primary">Call {site.phone}</a>
        <a href="/new-patients#request" class="btn btn--ghost">Send a request</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero { background: linear-gradient(180deg, var(--mist), var(--cream)); overflow: hidden; }
  .hero__inner { display: grid; grid-template-columns: 1.15fr .85fr; gap: 40px; align-items: center; padding-block: clamp(40px, 7vw, 84px); }
  .hero__copy .pill { margin-bottom: 18px; }
  .hero h1 { margin-top: 6px; }
  .hero h1 .hl { color: var(--crimson); }
  .hero__actions { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 26px; }
  .hero__art { display: grid; place-items: center; }
  .hero__heart { width: min(380px, 82%); filter: drop-shadow(0 18px 38px rgba(0,60,30,.18)); animation: floaty 6s ease-in-out infinite; }
  .hero__heart img { width: 100%; height: auto; display: block; }
  @keyframes floaty { 0%,100% { transform: translateY(0) } 50% { transform: translateY(-12px) } }
  @media (max-width: 860px) { .hero__inner { grid-template-columns: 1fr; } .hero__art { order: -1; } .hero__heart { width: 200px; } }

  .reassure { background: var(--forest); color: var(--cream); }
  .reassure__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; padding-block: 26px; text-align: center; }
  .reassure__grid div { display: flex; flex-direction: column; }
  .reassure__grid strong { font-family: var(--font-head); font-size: 1.4rem; color: #fff; }
  .reassure__grid span { color: #cfe6d6; font-size: .95rem; }
  @media (max-width: 620px) { .reassure__grid { grid-template-columns: 1fr; gap: 12px; } }

  .cost { display: grid; grid-template-columns: 1.3fr .7fr; gap: 34px; align-items: center; }
  @media (max-width: 820px) { .cost { grid-template-columns: 1fr; } }

  .quote { font-family: var(--font-head); font-size: clamp(1.3rem, 3vw, 1.9rem); color: var(--forest); line-height: 1.4; margin: 10px 0 14px; }

  .nurses { display: grid; grid-template-columns: 1.4fr .6fr; gap: 30px; align-items: center; }
  .nurses__actions { display: flex; flex-direction: column; gap: 12px; }
  @media (max-width: 820px) { .nurses { grid-template-columns: 1fr; } .nurses__actions { flex-direction: row; flex-wrap: wrap; } }
</style>
