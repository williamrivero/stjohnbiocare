---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
const benefits = [
  'SSS, PhilHealth & Pag-IBIG', '13th-month pay', 'Hazard pay', 'HMO card',
  'Free annual physical + hepatitis vaccination', '15 days annual leave',
  'Company loans', 'Staff service discounts',
];
---
<BaseLayout title="Careers" description="Join a foundation that invests in its people — strong benefits, real mentorship, and an empowerment culture." image="/images/photos/dsc_0040.webp">
  <PageHero
    image="/images/photos/dsc_0040.webp"
    alt="A St. John Biocare care team working together at a patient's bedside"
    eyebrow="Careers"
    title="Work somewhere that invests in you."
    subtitle="We're a foundation, so our people come first too — with an unusually strong benefits story and a culture of empowerment."
  />

  <section class="section">
    <div class="container" style="max-width:860px">
      <h2>Why work here</h2>
      <div style="display:flex;flex-wrap:wrap;gap:10px;margin:14px 0 30px">
        {benefits.map((b) => <span class="pill">{b}</span>)}
      </div>

      <h2>Open roles</h2>
      <p class="muted">Nurses, medical technologists, radiologic technologists, reuse technicians, and admin — across all five centers.</p>
      <div class="notice" style="margin-top:14px">
        Current openings and an application form (with resume upload) will be added here.
        In the meantime, tell us about yourself via the <a href="/new-patients#request">contact form</a>
        or email us.
      </div>
    </div>
  </section>
</BaseLayout>
