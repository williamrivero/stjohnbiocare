---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
const benefits = [
  'SSS, PhilHealth & Pag-IBIG', '13th-month pay', 'Hazard pay', 'HMO card',
  'Free annual physical + hepatitis vaccination', 'Free annual flu vaccine', '15 days annual leave',
  'Company loans', 'Staff service discounts',
];
---
<BaseLayout title="Careers" description="Join a foundation that invests in its people — strong benefits, real mentorship, and an empowerment culture." image="/images/og/og-careers.jpg">
  <PageHero
    image="/images/heroes/careers-hero.webp"
    alt="The full St. John Biocare team — nurses, physician, dietitian, social worker, front-desk and support staff — together inside a dialysis center"
    eyebrow="Careers"
    title="Work somewhere that invests in you."
    subtitle="We're a foundation, so our people come first too — with an unusually strong benefits story and a culture of empowerment."
  />

  <section class="section">
    <div class="container" style="max-width:860px">
      <h2>Why work here</h2>
      <div style="display:flex;flex-wrap:wrap;gap:10px;margin:14px 0 30px">
        {benefits.map((b) => <span class="pill">{b}</span>)}
      </div>

      <h2>Current openings</h2>
      <div id="dialysis-technician" class="card" style="margin-top:14px;scroll-margin-top:90px">
        <span class="pill" style="margin-bottom:10px">St. Josef Renal Care · Cainta, Rizal</span>
        <h3 style="font-size:1.4rem;margin-bottom:.2rem">Dialysis Technician <span style="color:var(--crimson);font-size:1rem;font-weight:700">· 2 openings</span></h3>
        <p class="muted" style="margin-bottom:1rem">Full-time · On-site — our new Cainta center, L475-A 3A &amp; 9097 Marcos Highway, San Isidro, Cainta, Rizal · 6 days/week, 8-hour shifts (early mornings)</p>

        <h4 style="color:var(--forest);margin-bottom:.4rem">What you'll do</h4>
        <ul style="line-height:1.9;margin-top:0">
          <li>Rinse, prime and reprocess dialyzers to <strong>AAMI standards</strong> — verifying each dialyzer is correctly matched to its patient every session, and disposing of any that fail the performance test.</li>
          <li>Prepare dialysis baths to the right formula, and set and calibrate the dialysis machines correctly.</li>
          <li>Prepare, rinse and disinfect the dialysis machines before and after every procedure; prepare and calibrate the reprocessing machines at the start of each day.</li>
          <li>Label, collect and store used and reprocessed dialyzers safely per protocol — preventing spillage and contamination — and record reuse numbers on the HD flow sheet.</li>
          <li>Maintain the <strong>RO (reverse osmosis) water system</strong> — daily backwashing and preventive maintenance for safe, adequate water — and conduct <strong>monthly bacteriology</strong> and <strong>bi-annual chemical</strong> water testing at DOH-accredited laboratories.</li>
          <li>Perform regular preventive maintenance on all HD machines, recording machine hours, repairs and issues, and keep the unit, equipment and water systems disinfected and performing well daily.</li>
          <li>Dispose of hazardous and non-hazardous waste properly in designated containers.</li>
          <li>Assist the HD team during emergencies and perform <strong>BLS</strong> in the event of cardiac or pulmonary arrest, and follow company policies and other tasks as assigned.</li>
        </ul>

        <h4 style="color:var(--forest);margin:1rem 0 .4rem">What we're looking for</h4>
        <ul style="line-height:1.9;margin-top:0">
          <li><strong>College level</strong> or <strong>college graduate</strong>.</li>
          <li><strong>Certificate of training as a Dialysis Technician</strong> from a structured program (three months or more) — covering renal function &amp; hemodialysis principles, HD machine structure and function, dialyzer reprocessing and eco priming, dialysis water treatment, concentrates and solutions, and infection control, waste management &amp; emergency preparedness.</li>
          <li>Valid <strong>NBI Clearance</strong> and <strong>Police Clearance</strong>.</li>
          <li><strong>No derogatory record</strong> — a clean work history and credentials.</li>
          <li>Updated <strong>Hepatitis B vaccination</strong> (or willing to complete it) and fit-to-work health clearance.</li>
          <li>Meticulous and strict about <strong>infection-control and safety protocols</strong>.</li>
          <li>Reliable team player who takes instruction well and can also work with minimal supervision.</li>
          <li>Willing to work an <strong>8-hour shift, 6 days a week</strong>, including early mornings (our clinics open at 5:30 AM).</li>
          <li>Prior experience as a dialysis technician is a plus.</li>
        </ul>

        <a class="btn btn--crimson" style="margin-top:8px"
           href="mailto:st.johnbiocare.hrmd@gmail.com?subject=Application%20%E2%80%94%20Dialysis%20Technician%2C%20St.%20Josef%20Renal%20Care%20%E2%80%93%20Cainta%20%28Attn%3A%20Ms.%20Denice%20Maglalad%2C%20HR%20Head%20Officer%29">Apply for this role</a>
      </div>

      <div id="cashier" class="card" style="margin-top:20px;scroll-margin-top:90px">
        <span class="pill" style="margin-bottom:10px">Core Renal Center · Makati</span>
        <h3 style="font-size:1.4rem;margin-bottom:.2rem">Cashier / Front Desk Officer</h3>
        <p class="muted" style="margin-bottom:1rem">Full-time · On-site — Santillan, Makati · 6 days/week, 8-hour shifts (early mornings)</p>

        <h4 style="color:var(--forest);margin-bottom:.4rem">What you'll do</h4>
        <ul style="line-height:1.9;margin-top:0">
          <li>Warmly welcome and assist patients and visitors at the front desk.</li>
          <li>Handle payments, issue official receipts, and reconcile the daily cash on hand.</li>
          <li>Keep accurate records, logs and reports using <strong>Microsoft Excel and Word</strong>.</li>
          <li>Assist with PhilHealth and billing paperwork together with the liaison officer.</li>
          <li>Answer phone and Messenger inquiries; schedule and confirm dialysis sessions.</li>
          <li>Keep patient files organized and strictly confidential.</li>
          <li>Coordinate with nurses and admin on smooth daily operations, and keep the reception area clean and welcoming.</li>
        </ul>

        <h4 style="color:var(--forest);margin:1rem 0 .4rem">What we're looking for</h4>
        <ul style="line-height:1.9;margin-top:0">
          <li>At least <strong>college level</strong> (college graduate an advantage).</li>
          <li>Working know-how in <strong>Microsoft Excel spreadsheets</strong> and <strong>Microsoft Word</strong>.</li>
          <li>Valid <strong>NBI Clearance</strong> and <strong>Police Clearance</strong>.</li>
          <li><strong>No derogatory record</strong> — a clean work history and credentials.</li>
          <li>Trustworthy and accurate in handling cash.</li>
          <li>Warm, patient, customer-service orientation with clients and families.</li>
          <li>Good communication skills in Filipino and English.</li>
          <li>Detail-oriented, organized, and dependable.</li>
          <li>Willing to work an <strong>8-hour shift, 6 days a week</strong>, including early mornings (our clinics open at 5:30 AM).</li>
          <li>Basic bookkeeping or front-desk experience is a plus.</li>
        </ul>

        <a class="btn btn--crimson" style="margin-top:8px"
           href="mailto:st.johnbiocare.hrmd@gmail.com?subject=Application%20%E2%80%94%20Cashier%2FFront%20Desk%20Officer%2C%20Core%20Renal%20Center%20(Attn%3A%20Ms.%20Denice%20Maglalad%2C%20HR%20Head%20Officer)">Apply for this role</a>
      </div>

      <div id="utility-aide" class="card" style="margin-top:20px;scroll-margin-top:90px">
        <span class="pill" style="margin-bottom:10px">Core Renal Center · Makati</span>
        <h3 style="font-size:1.4rem;margin-bottom:.2rem">Utility Aide</h3>
        <p class="muted" style="margin-bottom:1rem">Full-time · On-site — Santillan, Makati · 6 days/week, 8-hour shifts (early mornings)</p>

        <h4 style="color:var(--forest);margin-bottom:.4rem">What you'll do</h4>
        <ul style="line-height:1.9;margin-top:0">
          <li>Keep the center spotless — clean and disinfect the treatment area, reception, comfort rooms and utility areas daily, following our <strong>infection-control protocols</strong>.</li>
          <li>Handle proper <strong>waste segregation and disposal</strong>, including clinical / biohazard waste, per protocol.</li>
          <li>Support the dialyzer-reprocessing and supply areas — keep them clean, orderly and well-stocked.</li>
          <li>Manage linens and laundry; restock consumables and supplies.</li>
          <li>Help receive and store deliveries; move and arrange supplies and equipment.</li>
          <li>Run errands and assist the nurses and admin staff with day-to-day non-clinical tasks.</li>
          <li>Report any maintenance or safety concern promptly, and help keep the whole center safe and welcoming.</li>
        </ul>

        <h4 style="color:var(--forest);margin:1rem 0 .4rem">What we're looking for</h4>
        <ul style="line-height:1.9;margin-top:0">
          <li>At least a <strong>High School graduate</strong> (Senior High School an advantage).</li>
          <li>Physically fit and able to do manual work — standing, lifting and cleaning — for an 8-hour shift.</li>
          <li>Willing to follow strict <strong>sanitation, infection-control and safety protocols</strong>.</li>
          <li>Hardworking, reliable, honest, and mindful of personal hygiene.</li>
          <li>Valid <strong>NBI Clearance</strong> and <strong>Police Clearance</strong>.</li>
          <li><strong>No derogatory record</strong> — a clean work history and credentials.</li>
          <li>Updated <strong>Hepatitis B vaccination</strong> (or willing to complete it) and fit-to-work health clearance.</li>
          <li>A good team player who takes instruction well and can also work with minimal supervision.</li>
          <li>Willing to work an <strong>8-hour shift, 6 days a week</strong>, including early mornings (our clinics open at 5:30 AM).</li>
          <li>Experience in a clinic, hospital or dialysis center is a plus.</li>
        </ul>

        <a class="btn btn--crimson" style="margin-top:8px"
           href="mailto:st.johnbiocare.hrmd@gmail.com?subject=Application%20%E2%80%94%20Utility%20Aide%2C%20Core%20Renal%20Center%20(Attn%3A%20Ms.%20Denice%20Maglalad%2C%20HR%20Head%20Officer)">Apply for this role</a>
      </div>

      <div id="philhealth-coordinator-concepcion" class="card" style="margin-top:20px;scroll-margin-top:90px">
        <span class="pill" style="margin-bottom:10px">St. Josef Renal Care · Marikina (Concepcion)</span>
        <h3 style="font-size:1.4rem;margin-bottom:.2rem">PhilHealth Coordinator</h3>
        <p class="muted" style="margin-bottom:1rem">Full-time · On-site — St. Josef Renal Care, Concepcion, Marikina · 6 days/week, 8-hour shifts</p>

        <h4 style="color:var(--forest);margin-bottom:.4rem">What you'll do</h4>
        <ul style="line-height:1.9;margin-top:0">
          <li>Process and file the center's <strong>PhilHealth (PHIC) claims</strong> for every hemodialysis session — accurately and within the filing deadlines.</li>
          <li>Verify each patient's PhilHealth <strong>eligibility, membership status, and contribution requirements</strong>, and keep member records complete and up to date.</li>
          <li>Prepare, review, and submit all required PhilHealth <strong>forms and supporting documents</strong> (claim forms, member data records, attachments), coordinating with the nurses, cashier, and attending nephrologist for complete documentation.</li>
          <li><strong>Monitor and follow up</strong> on filed claims — resolving returned, denied, or deficient claims promptly with PhilHealth.</li>
          <li>Keep organized <strong>records and logs</strong> of claims filed, approved, denied, and reimbursed, and prepare periodic summaries for management.</li>
          <li><strong>Assist patients and families</strong> with PhilHealth membership, eligibility, and benefit availment — explaining requirements clearly and patiently.</li>
          <li>Coordinate other applicable third-party payors (e.g., <strong>PCSO, DSWD</strong>) where relevant.</li>
          <li>Stay current with <strong>PhilHealth circulars and DOH requirements</strong>, and help keep the center compliant.</li>
          <li>Keep all patient information <strong>strictly confidential</strong>, in line with the Data Privacy Act.</li>
        </ul>

        <h4 style="color:var(--forest);margin:1rem 0 .4rem">What we're looking for</h4>
        <ul style="line-height:1.9;margin-top:0">
          <li>At least a <strong>College Graduate</strong> (College level considered).</li>
          <li><strong>Knowledge of PhilHealth claims and processing</strong> (a strong advantage; willing to be trained if not).</li>
          <li><strong>Computer literate</strong> — Microsoft Excel and Word; accurate and meticulous with records and figures.</li>
          <li>Detail-oriented, organized, honest, and dependable, with good follow-through.</li>
          <li>Good communication skills in <strong>Filipino and English</strong>, and a patient, helpful manner with client-patients and families.</li>
          <li>Valid <strong>NBI Clearance</strong> and <strong>Police Clearance</strong>.</li>
          <li><strong>No derogatory record</strong> — a clean work history and credentials.</li>
          <li>Willing to work an <strong>8-hour shift, 6 days a week</strong>.</li>
          <li>Prior experience in PhilHealth processing, medical billing, or a clinic/hospital setting is a plus.</li>
        </ul>

        <a class="btn btn--crimson" style="margin-top:8px"
           href="mailto:st.johnbiocare.hrmd@gmail.com?subject=Application%20%E2%80%94%20PhilHealth%20Coordinator%2C%20St.%20Josef%20Renal%20Care%20%E2%80%93%20Concepcion%20%28Attn%3A%20Ms.%20Denice%20Maglalad%2C%20HR%20Head%20Officer%29">Apply for this role</a>
      </div>

      <div id="philhealth-coordinator-cainta" class="card" style="margin-top:20px;scroll-margin-top:90px">
        <span class="pill" style="margin-bottom:10px">St. Josef Renal Care · Cainta, Rizal</span>
        <h3 style="font-size:1.4rem;margin-bottom:.2rem">PhilHealth Coordinator</h3>
        <p class="muted" style="margin-bottom:1rem">Full-time · On-site — our new Cainta center, L475-A 3A &amp; 9097 Marcos Highway, San Isidro, Cainta, Rizal · 6 days/week, 8-hour shifts</p>

        <h4 style="color:var(--forest);margin-bottom:.4rem">What you'll do</h4>
        <ul style="line-height:1.9;margin-top:0">
          <li>Process and file the center's <strong>PhilHealth (PHIC) claims</strong> for every hemodialysis session — accurately and within the filing deadlines.</li>
          <li>Verify each patient's PhilHealth <strong>eligibility, membership status, and contribution requirements</strong>, and keep member records complete and up to date.</li>
          <li>Prepare, review, and submit all required PhilHealth <strong>forms and supporting documents</strong> (claim forms, member data records, attachments), coordinating with the nurses, cashier, and attending nephrologist for complete documentation.</li>
          <li><strong>Monitor and follow up</strong> on filed claims — resolving returned, denied, or deficient claims promptly with PhilHealth.</li>
          <li>Keep organized <strong>records and logs</strong> of claims filed, approved, denied, and reimbursed, and prepare periodic summaries for management.</li>
          <li><strong>Assist patients and families</strong> with PhilHealth membership, eligibility, and benefit availment — explaining requirements clearly and patiently.</li>
          <li>Coordinate other applicable third-party payors (e.g., <strong>PCSO, DSWD</strong>) where relevant.</li>
          <li>Stay current with <strong>PhilHealth circulars and DOH requirements</strong>, and help keep the center compliant.</li>
          <li>Keep all patient information <strong>strictly confidential</strong>, in line with the Data Privacy Act.</li>
        </ul>

        <h4 style="color:var(--forest);margin:1rem 0 .4rem">What we're looking for</h4>
        <ul style="line-height:1.9;margin-top:0">
          <li>At least a <strong>College Graduate</strong> (College level considered).</li>
          <li><strong>Knowledge of PhilHealth claims and processing</strong> (a strong advantage; willing to be trained if not).</li>
          <li><strong>Computer literate</strong> — Microsoft Excel and Word; accurate and meticulous with records and figures.</li>
          <li>Detail-oriented, organized, honest, and dependable, with good follow-through.</li>
          <li>Good communication skills in <strong>Filipino and English</strong>, and a patient, helpful manner with client-patients and families.</li>
          <li>Valid <strong>NBI Clearance</strong> and <strong>Police Clearance</strong>.</li>
          <li><strong>No derogatory record</strong> — a clean work history and credentials.</li>
          <li>Willing to work an <strong>8-hour shift, 6 days a week</strong>.</li>
          <li>Prior experience in PhilHealth processing, medical billing, or a clinic/hospital setting is a plus.</li>
        </ul>

        <a class="btn btn--crimson" style="margin-top:8px"
           href="mailto:st.johnbiocare.hrmd@gmail.com?subject=Application%20%E2%80%94%20PhilHealth%20Coordinator%2C%20St.%20Josef%20Renal%20Care%20%E2%80%93%20Cainta%20%28Attn%3A%20Ms.%20Denice%20Maglalad%2C%20HR%20Head%20Officer%29">Apply for this role</a>
      </div>

      <h2 style="margin-top:34px">Other roles we hire for</h2>
      <p class="muted">Nurses, cashiers, PhilHealth liaison officers, and utility / ancillary personnel — across our centers.</p>

      <h2 style="margin-top:28px">How to apply</h2>
      <p>Apply <strong>online below</strong>, or email your application and résumé directly to our Human
      Resources Department. Kindly address your application to <strong>Ms. Denice Maglalad, HR Head
      Officer</strong>.</p>
      <div class="grid grid--2" style="margin-top:14px">
        <div class="card">
          <h3>St. John Biocare</h3>
          <p style="margin:0"><a href="mailto:st.johnbiocare.hrmd@gmail.com?subject=Job%20Application%20%E2%80%94%20Attn:%20Ms.%20Denice%20Maglalad,%20HR%20Head%20Officer">st.johnbiocare.hrmd@gmail.com</a></p>
        </div>
        <div class="card">
          <h3>St. Josef Renal Care</h3>
          <p style="margin:0"><a href="mailto:st.josefrenalcare.hrmd@gmail.com?subject=Job%20Application%20%E2%80%94%20Attn:%20Ms.%20Denice%20Maglalad,%20HR%20Head%20Officer">st.josefrenalcare.hrmd@gmail.com</a></p>
        </div>
      </div>
    </div>
  </section>

  <!-- Online application -->
  <section id="apply" class="section section--sand">
    <div class="container" style="max-width:720px">
      <div class="center" style="margin-bottom:22px">
        <p class="eyebrow">Apply online</p>
        <h2>Submit your application</h2>
        <p class="muted">Fill in your details and upload your résumé and requirements. Your application goes
        to our HR Department (Attn: Ms. Denice Maglalad, HR Head Officer).</p>
      </div>

      <form class="card" action="https://api.web3forms.com/submit" method="POST" enctype="multipart/form-data">
        <!-- Web3Forms routing (key ties delivery to the HR inbox) -->
        <input type="hidden" name="access_key" value="52209a70-96fc-4d8f-8c6b-d8e7e7a3fb9e" />
        <input type="hidden" name="subject" value="New job application — stjohnbiocare.com (Attn: Ms. Denice Maglalad, HR Head Officer)" />
        <input type="hidden" name="from_name" value="St. John Biocare — Careers" />
        <input type="hidden" name="redirect" value="https://stjohnbiocare.com/thank-you/" />
        <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off" />

        <div class="grid grid--2" style="gap:0 18px">
          <div class="form-field">
            <label for="ap-name">Full name</label>
            <input id="ap-name" name="Full name" type="text" required autocomplete="name" />
          </div>
          <div class="form-field">
            <label for="ap-position">Position applying for</label>
            <select id="ap-position" name="Position applying for">
              <option>Nurse</option>
              <option>Dialysis Technician</option>
              <option>Cashier / Front Desk Officer</option>
              <option>Utility Aide</option>
              <option>PhilHealth Coordinator</option>
              <option>PhilHealth Liaison Officer</option>
              <option>Utility / Ancillary personnel</option>
              <option>Other</option>
            </select>
          </div>
        </div>

        <div class="grid grid--2" style="gap:0 18px">
          <div class="form-field">
            <label for="ap-email">Email</label>
            <input id="ap-email" name="email" type="email" required />
          </div>
          <div class="form-field">
            <label for="ap-mobile">Mobile number</label>
            <input id="ap-mobile" name="Mobile number" type="tel" required />
          </div>
        </div>

        <div class="form-field">
          <label for="ap-where">Applying to</label>
          <select id="ap-where" name="Applying to">
            <option>No preference</option>
            <option>St. John Biocare</option>
            <option>Core Renal Center</option>
            <option>St. Josef Renal Care</option>
          </select>
        </div>

        <div class="form-field">
          <label for="ap-files">Upload your résumé &amp; requirements</label>
          <input id="ap-files" name="attachment" type="file" accept="image/*,application/pdf,.doc,.docx" multiple />
          <p class="muted" style="font-size:.82rem;margin:.3rem 0 0">
            Select multiple files (PDF, DOC, JPG or PNG, up to ~5&nbsp;MB total) — e.g. résumé, PRC ID (if
            applicable), NBI &amp; Police clearance. If your files are larger, attach the résumé here and
            email the rest to HR.
          </p>
        </div>

        <div class="form-field">
          <label for="ap-msg">Message (optional)</label>
          <textarea id="ap-msg" name="Message" placeholder="A short note about yourself or your experience."></textarea>
        </div>

        <label class="consent">
          <input type="checkbox" name="Consent (Data Privacy Act)" required />
          <span>I agree that St. John Biocare may process my information for recruitment purposes, in line
          with the Data Privacy Act of 2012 (RA&nbsp;10173).</span>
        </label>

        <div style="margin-top:18px">
          <button type="submit" class="btn btn--crimson">Submit application</button>
        </div>
      </form>
    </div>
  </section>
</BaseLayout>
