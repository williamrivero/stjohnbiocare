---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
const services = [
  { id: 'hemodialysis', title: 'Hemodialysis', text: 'Our core service. Modern machines, careful monitoring, strict infection control, and early-morning schedules built around working patients and caregivers.', img: '/images/photos/dsc_0033.webp', imgAlt: 'A dialyzer on a hemodialysis machine during a treatment session' },
  { id: 'modalities', title: 'A full range of dialysis modalities', text: 'Beyond standard sessions, we offer low-flux and high-flux hemodialysis, hemodiafiltration (HDF) at select branches, SLED (sustained low-efficiency dialysis) for more fragile patients, and isolated ultrafiltration (UF) for fluid removal — so your treatment can be matched to what your body needs.' },
  { id: 'physicians', title: 'Physicians on duty', text: 'A physician is on duty during clinic hours, so there is always a doctor watching over your treatment and ready to respond.' },
  { id: 'dietitian', title: 'Renal dietitians', text: 'Our renal dietitians help you build a kidney-friendly diet that fits Filipino food and your own preferences — practical guidance, not a lecture.' },
  { id: 'social', title: 'Social workers', text: 'Our social workers are on hand to help you navigate PhilHealth, costs, and the practical worries that come with dialysis.' },
  { id: 'diagnostics', title: 'Diagnostics & Laboratory', text: 'We coordinate the bloodwork and diagnostics dialysis patients need with reputable, experienced and well-known partner laboratories — reliable results, on time, without the extra runaround.' },
  { id: 'reuse', title: 'Dialyzer Reuse & Infection Control', text: 'Careful, protocol-driven dialyzer reprocessing and formal infection-control practices — the quiet work that keeps you safe.' },
  { id: 'education', title: 'Renal Education & Health Promotion', text: 'We explain kidney health in plain language, so you and your family understand what is happening and what to do.' },
];
---
<BaseLayout title="Services" description="Hemodialysis, diagnostics through trusted partner laboratories, dialyzer reprocessing, and renal education at St. John Biocare." image="/images/og/og-services.jpg">
  <PageHero
    image="/images/photos/dsc_0038.webp"
    alt="A St. John Biocare dialysis treatment area with monitoring equipment"
    eyebrow="Services"
    title="Everything your dialysis care needs."
    subtitle="Careful clinical work, explained in plain terms — with the safety details we're proud of."
  />
  <section class="section">
    <div class="container stack" style="max-width:820px">
      {services.map((s) => (
        <div id={s.id} class="card">
          <h2 style="font-size:1.4rem">{s.title}</h2>
          <p>{s.text}</p>
          {s.img && (
            <figure style="margin:16px 0 0">
              <img src={s.img} alt={s.imgAlt} loading="lazy"
                   style="max-width:300px;width:100%;height:auto;border-radius:12px;display:block" width="1328" height="2000" />
              <figcaption class="muted" style="font-size:.82rem;margin-top:6px">A dialyzer at work during a session — where your blood is gently cleaned.</figcaption>
            </figure>
          )}
        </div>
      ))}
      <p class="muted" style="font-size:.92rem">
        Confirming for launch: whether we also offer peritoneal / home dialysis,
        telemedicine follow-up, and vascular-access services.
      </p>
    </div>
  </section>

  <section class="section section--mist">
    <div class="container" style="max-width:820px">
      <p class="eyebrow">Quality &amp; safety</p>
      <h2>The safety work you don't always see.</h2>
      <p>Good dialysis is as much about what happens between sessions as during them. This is the
      standard we hold ourselves to, quietly, every week.</p>

      <div class="grid grid--2" style="margin-top:22px">
        <div class="card">
          <h3 style="font-size:1.15rem">Innovator-brand medicines</h3>
          <p style="margin:0">We use well-established, proven <strong>innovator (original-brand)</strong>
          pharmaceutical products — the original manufacturers' own, not substitutes — for your
          erythropoietin, intravenous iron and <strong>halal-certified heparin</strong>, and for all our
          materials and chemicals.</p>
        </div>
        <div class="card">
          <h3 style="font-size:1.15rem">Industry-leading machines, maker-calibrated</h3>
          <p style="margin:0">Every center runs <strong>industry-leading hemodialysis machines</strong>,
          calibrated regularly by their <strong>original manufacturers</strong> — so the equipment caring
          for you performs exactly as it should.</p>
        </div>
        <div class="card">
          <h3 style="font-size:1.15rem">Dual-pass RO water, in every center</h3>
          <p style="margin:0">All our water treatment systems use a <strong>dual-pass reverse-osmosis
          (RO)</strong> setup — the water is purified twice before it's used — so the water behind every
          session meets high purity standards across all our centers.</p>
        </div>
        <div class="card">
          <h3 style="font-size:1.15rem">Closed Sundays — but the work never stops</h3>
          <p style="margin:0">We close to patients on <strong>Sundays</strong>, and that's precisely when
          the behind-the-scenes work happens: <strong>wall-to-wall clinic disinfection</strong> and full
          servicing of our <strong>water treatment system</strong> — disinfection, calibration, resetting
          and maintenance. You come back to a center that has been cleaned and checked from top to bottom.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--sand" style="padding-block:44px">
    <div class="container" style="max-width:920px">
      <figure style="margin:0">
        <picture>
          <source srcset="/images/og/og-services.webp" type="image/webp" />
          <img src="/images/og/og-services.jpg" width="1200" height="630" loading="lazy"
               alt="St. John Biocare services at a glance: hemodialysis, physicians on duty, renal dietitians, and social workers."
               style="width:100%;height:auto;border-radius:14px;box-shadow:var(--shadow)" />
        </picture>
      </figure>
    </div>
  </section>
</BaseLayout>
