---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page not found">
  <section class="section center">
    <div class="container" style="max-width:560px">
      <p class="eyebrow">404</p>
      <h1>We couldn't find that page.</h1>
      <p class="lead" style="margin-inline:auto">It may have moved. Let's get you back on track.</p>
      <div class="hero__actions" style="justify-content:center;display:flex;gap:12px;flex-wrap:wrap;margin-top:20px">
        <a href="/" class="btn btn--primary">Go home</a>
        <a href="/centers" class="btn btn--ghost">Find a center</a>
      </div>
    </div>
  </section>
</BaseLayout>
