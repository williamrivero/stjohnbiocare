---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { site } from '../data/site';
---
<BaseLayout
  title="Thank you"
  description="Your message has reached St. John Biocare. A real person will get back to you soon."
  image="/images/og/og-contact.jpg"
  noindex={true}
>
  <PageHero
    image="/images/heroes/contact-hero.webp"
    alt="A St. John Biocare nurse warmly welcoming an elderly couple at the center's bright reception entrance"
    eyebrow="Message sent"
    title="Thank you — we've got it."
    subtitle="Your message is now with our team. A real person will read it and get back to you."
  />

  <section class="section">
    <div class="container" style="max-width:720px">
      <div class="card" style="text-align:center">
        <div style="font-size:2.4rem;line-height:1;margin-bottom:.4rem" aria-hidden="true">💚</div>
        <h2 style="font-size:1.5rem;margin:.2rem 0 .6rem">We'll be in touch soon.</h2>
        <p style="margin:0 auto;max-width:56ch">
          Thank you for reaching out to St. John Biocare. We've received your message and someone from
          our team will respond as soon as we can — usually within one working day. If you attached a
          file, it came through with your message.
        </p>
      </div>

      <div class="notice" style="margin-top:22px">
        <strong>Need to talk to us sooner?</strong>
        <p style="margin:.4rem 0 0">
          If your concern is urgent, please call us directly at
          <a href={site.phoneHref}>{site.phone}</a>. If you're having a medical emergency, call your
          nearest center or go to the nearest hospital emergency room right away.
        </p>
      </div>

      <div style="display:flex;flex-wrap:wrap;gap:12px;justify-content:center;margin-top:26px">
        <a class="btn btn--crimson" href="/">Back to home</a>
        <a class="btn btn--ghost" href="/kidney-health">Explore kidney health</a>
        <a class="btn btn--ghost" href="/centers">Find a center</a>
      </div>
    </div>
  </section>
</BaseLayout>
