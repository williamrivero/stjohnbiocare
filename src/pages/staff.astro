---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';

// ---------------------------------------------------------------------------
// STAFF PORTAL — a login-style landing page. It holds NO secrets: the real
// sign-in is Google's (the Shared Drive + Chat only let in people you've added
// by email). There is deliberately NO password field here — "Sign in with
// Google" hands off to real Google authentication.
//
// TO GO LIVE: paste the Shared Drive link between the quotes below.
// (In Google Drive: open the Shared Drive → Share → "Copy link".)
// ---------------------------------------------------------------------------
const PORTAL_URL = 'https://drive.google.com/drive/folders/1RJvX28kwzx6GGkscX3UabgwJV1JFti3l';  // Staff Portal shared folder — access is per-email; keep General access = Restricted
const CHAT_URL = 'https://chat.google.com';   // Google Chat — universal sign-in link
const ADMIN_CONTACT = site.email;             // who grants access (per-person, by email)
const ready = PORTAL_URL.length > 0;
---
<BaseLayout
  title="Staff Portal"
  description="Private sign-in for St. John Biocare unit directors, head nurses, and admins."
  noindex={true}
>
  <section class="auth-wrap">
    <div class="auth-card" data-auth>

      <!-- SIGN IN (default, left) -->
      <div class="auth-panel auth-signin">
        <span class="auth-eyebrow">Staff only</span>
        <h1 class="auth-title">Staff Portal</h1>
        <p class="auth-sub">Sign in with your <strong>work Google account</strong> to reach protocols,
        the employee handbook, internal memos, and Team Chat.</p>

        {ready ? (
          <a class="gbtn" href={PORTAL_URL} target="_blank" rel="noopener">
            <svg width="18" height="18" viewBox="0 0 48 48" aria-hidden="true">
              <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
              <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
              <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.28-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
              <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
            </svg>
            <span>Sign in with Google</span>
          </a>
        ) : (
          <p class="auth-note"><strong>The secure drive is being set up.</strong> Your Shared Drive
          sign-in will appear here shortly.</p>
        )}

        <a class="auth-alt" href={CHAT_URL} target="_blank" rel="noopener">💬 Open Team Chat</a>
        <a class="auth-need" href={`mailto:${ADMIN_CONTACT}?subject=Staff%20Portal%20access%20request`}>Need access? Email us →</a>

        <p class="auth-meta">Protocols · Employee Handbook · Internal Memos · Team Chat</p>
        <a class="auth-back" href="/">← Back to the main site</a>
      </div>

      <!-- NEED ACCESS (revealed on slide, right) -->
      <div class="auth-panel auth-request">
        <h2 class="auth-title">Need access?</h2>
        <p class="auth-sub">Access is granted <strong>per person, by email</strong>. Send us the work
        Google address you'd like added and we'll set you up.</p>
        <a class="gbtn gbtn--solid" href={`mailto:${ADMIN_CONTACT}?subject=Staff%20Portal%20access%20request`}>
          ✉ Email {ADMIN_CONTACT}
        </a>
        <p class="auth-meta">For unit directors, head nurses, and admins.</p>
      </div>

      <!-- SLIDING GRADIENT OVERLAY -->
      <div class="auth-ov-container">
        <div class="auth-ov">
          <div class="auth-ov__panel auth-ov__left">
            <h2>Already on the team?</h2>
            <p>Sign in with your Google account to jump right back in.</p>
            <button class="ghost" type="button" data-auth-to="signin">Sign in</button>
          </div>
          <div class="auth-ov__panel auth-ov__right">
            <h2>Welcome, team 👋</h2>
            <p>Everything in one place — protocols, the handbook, memos, and your Team Chat.</p>
            <button class="ghost" type="button" data-auth-to="request">Need access?</button>
          </div>
        </div>
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  .auth-wrap {
    min-height: 80vh; display: flex; align-items: center; justify-content: center;
    padding: clamp(28px, 6vw, 72px) 20px;
    background: linear-gradient(160deg, var(--mist), var(--cream));
  }
  .auth-card {
    position: relative; width: min(880px, 100%); min-height: 540px;
    background: #fff; border-radius: 22px; box-shadow: 0 26px 64px rgba(0, 60, 30, .18); overflow: hidden;
  }

  /* Form panels (left half by default) */
  .auth-panel {
    position: absolute; top: 0; height: 100%; width: 50%;
    display: flex; flex-direction: column; justify-content: center;
    padding: 0 clamp(26px, 4.5%, 54px);
    transition: transform .6s ease-in-out, opacity .6s ease-in-out;
  }
  .auth-signin  { left: 0; z-index: 2; }
  .auth-request { left: 0; opacity: 0; z-index: 1; }
  .auth-card.active .auth-signin  { transform: translateX(100%); opacity: 0; z-index: 1; }
  .auth-card.active .auth-request { transform: translateX(100%); opacity: 1; z-index: 5; }

  .auth-eyebrow { font-family: var(--font-head); font-weight: 700; text-transform: uppercase; letter-spacing: .08em; font-size: .74rem; color: var(--life); }
  .auth-title { font-size: clamp(1.6rem, 4vw, 2.1rem); margin: 6px 0 10px; color: var(--forest); line-height: 1.1; }
  .auth-sub { margin: 0 0 22px; color: var(--ink-soft); line-height: 1.55; font-size: .96rem; }
  .auth-note { margin: 0 0 18px; padding: 12px 14px; border-radius: 12px; background: color-mix(in srgb, var(--forest) 7%, #fff); color: var(--ink-soft); font-size: .92rem; }
  .auth-meta { margin: 18px 0 0; color: var(--ink-soft); font-size: .8rem; }
  .auth-back { margin-top: 8px; font-weight: 700; text-decoration: none; color: var(--forest); font-size: .9rem; }

  /* Google button */
  .gbtn {
    display: inline-flex; align-items: center; gap: 11px; align-self: flex-start;
    padding: 12px 20px; border-radius: 999px; text-decoration: none; cursor: pointer;
    font-family: var(--font-body); font-weight: 700; font-size: 1rem;
    background: #fff; color: #3c4043; border: 1.5px solid var(--border);
    box-shadow: 0 2px 8px rgba(0,0,0,.06); transition: box-shadow .15s, transform .15s;
  }
  .gbtn:hover { box-shadow: 0 6px 16px rgba(0,0,0,.12); transform: translateY(-1px); }
  .gbtn--solid { background: var(--forest); color: #fff; border-color: var(--forest); }
  .auth-alt { margin-top: 14px; align-self: flex-start; font-weight: 700; text-decoration: none; color: var(--forest); font-size: .95rem; }
  .auth-need { display: none; align-self: flex-start; margin-top: 12px; font-weight: 700; text-decoration: none; color: var(--forest); font-size: .95rem; }

  /* Sliding gradient overlay */
  .auth-ov-container { position: absolute; top: 0; left: 50%; width: 50%; height: 100%; overflow: hidden; z-index: 100; transition: transform .6s ease-in-out; }
  .auth-card.active .auth-ov-container { transform: translateX(-100%); }
  .auth-ov { position: relative; left: -100%; width: 200%; height: 100%; color: #fff; transition: transform .6s ease-in-out;
    background: linear-gradient(135deg, var(--life), var(--forest)); }
  .auth-card.active .auth-ov { transform: translateX(50%); }
  .auth-ov__panel { position: absolute; top: 0; height: 100%; width: 50%; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 0 clamp(24px, 4%, 44px); transition: transform .6s ease-in-out; }
  .auth-ov__panel h2 { color: #fff; font-size: clamp(1.4rem, 3.4vw, 1.9rem); margin: 0 0 10px; }
  .auth-ov__panel p { color: #eafaf0; margin: 0 0 22px; line-height: 1.55; font-size: .95rem; }
  .auth-ov__left  { left: 0;  transform: translateX(-20%); }
  .auth-card.active .auth-ov__left  { transform: translateX(0); }
  .auth-ov__right { right: 0; transform: translateX(0); }
  .auth-card.active .auth-ov__right { transform: translateX(20%); }
  .ghost {
    background: transparent; color: #fff; border: 1.6px solid rgba(255,255,255,.85);
    padding: 11px 26px; border-radius: 999px; font-family: var(--font-body); font-weight: 700; font-size: .95rem;
    cursor: pointer; transition: background .15s, transform .15s;
  }
  .ghost:hover { background: rgba(255,255,255,.16); transform: translateY(-1px); }

  /* Mobile: stack (no slider) — gradient banner on top, sign-in below */
  @media (max-width: 720px) {
    .auth-card { min-height: 0; }
    .auth-ov-container, .auth-card.active .auth-ov-container { position: static; width: 100%; height: auto; transform: none; }
    .auth-ov { position: static; left: 0; width: 100%; height: auto; transform: none !important; }
    .auth-ov__panel { position: static; width: 100%; transform: none !important; padding: 30px 26px; }
    .auth-ov__left { display: none; }              /* only the welcome panel on mobile */
    .auth-panel { position: static; width: 100%; opacity: 1 !important; transform: none !important; padding: 30px 26px; }
    .auth-request { display: none; }               /* request access via the email link below */
    .auth-signin { z-index: 1; }
    .auth-need { display: inline-block; }           /* mobile: persistent request-access link */
    .auth-ov__panel .ghost { display: none; }       /* mobile: slider toggle not needed */
  }
</style>

<script>
  function initAuth() {
    const card = document.querySelector('[data-auth]');
    if (!card) return;
    card.querySelectorAll('[data-auth-to]').forEach((btn) => {
      btn.addEventListener('click', () => {
        card.classList.toggle('active', btn.getAttribute('data-auth-to') === 'request');
      });
    });
  }
  initAuth();
  document.addEventListener('astro:page-load', initAuth);
</script>
