---
import BaseLayout from '../layouts/BaseLayout.astro';
import BiocareValues from '../components/BiocareValues.astro';
---
<BaseLayout title="About Us" description="St. John Biocare is a SEC-registered foundation born from one family's experience of kidney failure — our story, mission, values and leadership.">
  <section class="section" style="background:linear-gradient(180deg,var(--mist),var(--cream));padding-block:52px">
    <div class="container" style="max-width:800px">
      <p class="eyebrow">Our story</p>
      <h1>A foundation, born from a real family story.</h1>
      <p class="lead">
        St. John Biocare & Dialysis Center Foundation, Inc. is not a corporate chain.
        We are a registered foundation — and that difference is the whole point.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width:760px" class:list={['stack']}>
      <p>
        The idea came from <strong>Mr. Jose Co</strong>, whose mother developed end-stage
        renal disease. After her hospital treatment she moved to outpatient dialysis, and
        what the family experienced at existing free-standing centers convinced him there
        had to be <em>a better alternative</em>. He built it — together with his childhood
        friend and partner, <strong>Mr. Rodrigo Ko</strong>.
      </p>
      <p>
        St. John Biocare was registered with the SEC on <strong>June 28, 2011</strong>, and
        opened its first clinic in Quezon City on <strong>October 16, 2011</strong>. As a
        non-stock foundation, we answer to a mission rather than to shareholders — which is
        why we can lead with the patient, and mean it.
      </p>

      <div class="notice">
        <strong>Our care philosophy</strong>
        <p style="margin:.4rem 0 0">
          “The St. John Biocare Way is to put the patient first… we must see the world through
          the eyes of our patients and their families.” We call the people we serve
          <strong>client-patients</strong>. And we hold to one line: <em>Dedicated to all of us.</em>
        </p>
      </div>
    </div>
  </section>

  <section class="section section--sand">
    <div class="container" style="max-width:820px">
      <div class="grid grid--2">
        <div class="card">
          <h2 style="font-size:1.35rem">Our vision</h2>
          <p><em>“To become the leading free-standing dialysis center and diagnostic facility
          in providing exemplary service to patients with end-stage renal disease.”</em></p>
        </div>
        <div class="card">
          <h2 style="font-size:1.35rem">Our mission</h2>
          <p><em>“To provide the best-quality expert clinical care through state-of-the-art,
          innovative and affordable hemodialysis treatments and diagnostics manned by
          outstanding and compassionate personnel, responsive to the needs of our patients.”</em></p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="center" style="margin-bottom:30px">
        <p class="eyebrow">What we stand for</p>
        <h2>The BIOCARE values.</h2>
      </div>
      <BiocareValues />
    </div>
  </section>

  <section class="section section--mist">
    <div class="container" style="max-width:820px">
      <p class="eyebrow">Leadership &amp; medical team</p>
      <h2>The people who lead the care.</h2>
      <div class="grid grid--2" style="margin-top:18px">
        <div class="card"><h3>Robina Marie A. Ko</h3><p class="muted">President &amp; CEO</p></div>
        <div class="card"><h3>Dr. Vimar A. Luz</h3><p class="muted">Head Nephrologist</p></div>
        <div class="card"><h3>Dr. William Gregory M. Rivero</h3><p class="muted">Senior Medical Director</p></div>
        <div class="card"><h3>Mrs. Mercy J. Alhambra</h3><p class="muted">Nursing Director</p></div>
      </div>
      <p class="muted" style="margin-top:16px;font-size:.9rem">
        Plus each center's Medical Director and Head Nurse. Full bios and photos to be added.
      </p>
    </div>
  </section>
</BaseLayout>
