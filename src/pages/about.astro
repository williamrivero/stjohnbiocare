---
import BaseLayout from '../layouts/BaseLayout.astro';
import BiocareValues from '../components/BiocareValues.astro';
import PageHero from '../components/PageHero.astro';
---
<BaseLayout title="About Us" description="St. John Biocare is a SEC-registered foundation born from one family's experience of kidney failure — our story, mission, values and leadership." image="/images/heroes/about-hero.webp">
  <PageHero
    image="/images/heroes/about-hero.webp"
    alt="An adult son resting a reassuring hand on his elderly father's shoulder, both smiling"
    eyebrow="Our story"
    title="A foundation, born from a real family story."
    subtitle="St. John Biocare & Dialysis Center Foundation, Inc. is not a corporate chain. We are a registered foundation — and that difference is the whole point."
  />

  <section class="section">
    <div class="container" style="max-width:760px" class:list={['stack']}>
      <p>
        The idea came from a son whose mother developed end-stage renal disease. After her
        hospital treatment she moved to outpatient dialysis, and what the family experienced
        at existing free-standing centers convinced him there had to be
        <em>a better alternative</em>. He built it together with a lifelong friend and partner.
      </p>
      <p>
        St. John Biocare was registered with the SEC on <strong>June 28, 2011</strong>, and
        opened its first clinic in Quezon City on <strong>October 16, 2011</strong>. As a
        non-stock foundation, we answer to a mission rather than to shareholders — which is
        why we can lead with the patient, and mean it.
      </p>

      <div class="notice">
        <strong>Our care philosophy</strong>
        <p style="margin:.4rem 0 0">
          “The St. John Biocare Way is to put the patient first… we must see the world through
          the eyes of our patients and their families.” We call the people we serve
          <strong>client-patients</strong>. And we hold to one line: <em>Dedicated to all of us.</em>
        </p>
      </div>
    </div>
  </section>

  <section class="section section--sand">
    <div class="container" style="max-width:820px">
      <div class="grid grid--2">
        <div class="card">
          <h2 style="font-size:1.35rem">Our vision</h2>
          <p><em>“To become the leading free-standing dialysis center and diagnostic facility
          in providing exemplary service to patients with end-stage renal disease.”</em></p>
        </div>
        <div class="card">
          <h2 style="font-size:1.35rem">Our mission</h2>
          <p><em>“To provide the best-quality expert clinical care through state-of-the-art,
          innovative and affordable hemodialysis treatments and diagnostics manned by
          outstanding and compassionate personnel, responsive to the needs of our patients.”</em></p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="center" style="margin-bottom:30px">
        <p class="eyebrow">What we stand for</p>
        <h2>The BIOCARE values.</h2>
      </div>
      <BiocareValues />
    </div>
  </section>

  <section class="section section--forest">
    <div class="container center" style="max-width:760px">
      <p class="eyebrow">More than procedures</p>
      <h2>We build patient communities.</h2>
      <p style="color:#e5f3e9;font-size:1.15rem">
        At St. John Biocare, we don't just perform procedures — we <strong>build and espouse patient
        communities</strong>. Dialysis is a shared journey, so we bring patients, families and staff
        together to support one another, learn, and find strength in good company. Here, you are never
        just a case — you belong.
      </p>
    </div>
  </section>

  <section class="section section--mist">
    <div class="container" style="max-width:820px">
      <p class="eyebrow">Leadership &amp; medical team</p>
      <h2>Experienced hands, at every level.</h2>
      <div class="grid grid--2" style="margin-top:18px">
        <div class="card"><h3>President &amp; CEO</h3><p class="muted">Leads the foundation's direction and day-to-day operations.</p></div>
        <div class="card"><h3>Head Nephrologist</h3><p class="muted">Oversees clinical nephrology care across all our centers.</p></div>
        <div class="card"><h3>Senior Medical Director</h3><p class="muted">Guides medical standards and the quality of care.</p></div>
        <div class="card"><h3>Nursing Director</h3><p class="muted">Leads nursing practice, training and patient safety.</p></div>
      </div>
      <p class="muted" style="margin-top:16px;font-size:.9rem">
        Each center is also led by its own Medical Director and Head Nurse.
      </p>
    </div>
  </section>
</BaseLayout>
