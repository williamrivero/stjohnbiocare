---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { openBranches } from '../data/branches';
import { centerKeys, DEFAULT_CENTER_KEY as DEFAULT_KEY } from '../data/centerKeys';

const faqs = [
  { q: 'How do I start dialysis with you?', a: "Send an appointment request below, or call your nearest center. We'll review your records, explain the schedule and costs clearly, and get you booked — often within a few days." },
  { q: 'Do I need a doctor’s referral first?', a: "A referral and recent labs help us start smoothly, but if you don't have them yet, send a request anyway — we'll guide you on exactly what to bring." },
  { q: 'What should I bring to my first visit?', a: 'A valid ID, your PhilHealth Member Data Record (MDR), any referral and recent lab results, and a list of your current medicines. A trusted companion is always welcome too.' },
  { q: 'Does PhilHealth cover my dialysis?', a: 'Yes. PhilHealth has a hemodialysis benefit for qualified members that covers most of the cost of each session. As a private center, the government’s No Balance Billing policy doesn’t apply here — but we work to keep any out-of-pocket amount to a minimum, limited to optional add-ons, certain laboratories and unforeseen expenses. We’re also HMO-accredited and accept various forms of payment — bring your MDR or HMO card and we’ll walk you through the real numbers.', more: { href: '/kidney-health/philhealth-cost', label: 'PhilHealth & the cost of dialysis' } },
  { q: 'Can I transfer from another dialysis center?', a: 'Yes, and it is entirely your right. Bring your latest dialysis records, labs and prescription, and we’ll take care of continuity so there is no gap in your treatment.', more: { href: '/kidney-health/transfer-of-care', label: 'Transferring your care' } },
  { q: 'Do I need to change my nephrologist if I transfer to St. John?', a: 'No. For continuity of care, we actually encourage you to stay under the care of your own nephrologist. The only exception is a practical one: if logistical obstacles make it hard to sign your PhilHealth claim forms on time, your nephrologist may choose to transfer your care to one of our affiliated nephrologists.' },
  { q: 'What happens during my first session?', a: 'You’ll meet the nurse and doctor, we’ll go over your records together, explain everything in plain language, and answer your questions before anything begins.', more: { href: '/kidney-health/starting-dialysis', label: 'Starting dialysis: what to expect' } },
  { q: 'Is this form for emergencies?', a: 'No. This form is for appointments and questions only. If you are having a medical emergency, call your nearest center or go to the nearest hospital emergency room right away.' },
];
---
<BaseLayout title="New Patients" description="Starting or transferring dialysis care at St. John Biocare — what to bring, what to expect, and how to request an appointment." image="/images/og/og-new-patients.jpg">
  <PageHero
    image="/images/heroes/new-patients-hero.webp"
    alt="A St. John Biocare team warmly welcoming a new patient and their family, walking them through what to expect"
    eyebrow="New patients"
    title="Starting with us is simpler than you fear."
    subtitle="Whether this is your first dialysis session or you're moving from a hospital or another center, here's exactly what happens — and how to reach us."
  />

  <section class="section">
    <div class="container grid grid--2">
      <div class="card">
        <h2 style="font-size:1.4rem">Your first visit</h2>
        <p class="muted">Please bring:</p>
        <ul style="line-height:1.9">
          <li>A valid ID</li>
          <li>Your PhilHealth Member Data Record (MDR)</li>
          <li>Referral and recent lab results, if any</li>
          <li>A list of your current medicines</li>
        </ul>
        <p>You'll meet the nurse and doctor, we'll review your records, and we'll explain the schedule and costs before anything begins.</p>
      </div>
      <div class="card">
        <h2 style="font-size:1.4rem">Transferring your care</h2>
        <p>Moving from a hospital or another dialysis center is common and easy. Bring your latest dialysis records, lab results and medication list, and we'll take care of continuity so there's no gap in your treatment.</p>
        <p class="muted" style="font-size:.9rem">Not sure what you have? Just send a request below — we'll guide you.</p>
      </div>
    </div>
  </section>

  <!-- YOU BELONG -->
  <section class="section section--forest">
    <div class="container center" style="max-width:760px">
      <p class="eyebrow">More than procedures</p>
      <h2>We build patient communities.</h2>
      <p style="color:#e5f3e9;font-size:1.15rem">
        At St. John Biocare, we don't just perform procedures — we <strong>build and espouse patient
        communities</strong>. Dialysis is a shared journey, so we bring patients, families and staff
        together to support one another, learn, and find strength in good company. Here, you are never
        just a case — you belong.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container stack" style="max-width:760px">
      <div class="center" style="margin-bottom:26px">
        <p class="eyebrow">Common questions</p>
        <h2>Starting dialysis — your questions, answered.</h2>
      </div>
      {faqs.map((f) => (
        <details class="faq">
          <summary>{f.q}</summary>
          <div class="faq__a">
            <p style="margin:0">{f.a}</p>
            {f.more && <p style="margin:.5rem 0 0"><a href={f.more.href}>{f.more.label} →</a></p>}
          </div>
        </details>
      ))}
      <p class="muted" style="font-size:.9rem;margin-top:8px">
        Still have a question? <a href="#request">Send us a message</a> — a real person will reply.
      </p>
    </div>
  </section>

  <!-- INQUIRY FORM -->
  <section id="request" class="section section--sand">
    <div class="container" style="max-width:720px">
      <div class="center" style="margin-bottom:26px">
        <p class="eyebrow">Request an appointment</p>
        <h2>Tell us a little, and a real person will reply.</h2>
        <p class="muted">Prefer to chat? Message us on Messenger or Viber, or call your nearest center.</p>
      </div>

      <form id="appt-form" class="card" action="https://api.web3forms.com/submit" method="POST" enctype="multipart/form-data">
        <!-- Web3Forms routing — access_key is swapped to the chosen center by JS (defaults to Quezon Avenue). -->
        <input type="hidden" id="appt-access-key" name="access_key" value={DEFAULT_KEY} data-default={DEFAULT_KEY} />
        <input type="hidden" name="subject" value="New appointment request — stjohnbiocare.com" />
        <input type="hidden" name="from_name" value="St. John Biocare — Appointments" />
        <input type="hidden" name="redirect" value="https://stjohnbiocare.com/thank-you/" />
        <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off" />
        <div class="grid grid--2" style="gap:0 18px">
          <div class="form-field">
            <label for="name">Your name</label>
            <input id="name" name="Name" type="text" required autocomplete="name" />
          </div>
          <div class="form-field">
            <label for="contact">Phone or email</label>
            <input id="contact" name="Contact (phone or email)" type="text" required />
          </div>
        </div>

        <div class="grid grid--2" style="gap:0 18px">
          <div class="form-field">
            <label for="branch">Preferred center</label>
            <select id="branch" name="Preferred center">
              <option value="">No preference</option>
              {openBranches.map((b) => <option value={`${b.foundation} — ${b.name}`} data-key={centerKeys[b.slug]}>{b.foundation} — {b.name}</option>)}
            </select>
          </div>
          <div class="form-field">
            <label for="type">Are you…</label>
            <select id="type" name="Patient type">
              <option value="new">A new dialysis patient</option>
              <option value="transfer">Transferring from another center</option>
              <option value="asking">Just asking a question</option>
            </select>
          </div>
        </div>

        <div class="form-field">
          <label for="philhealth">Are you a PhilHealth member?</label>
          <select id="philhealth" name="PhilHealth member">
            <option value="yes">Yes</option>
            <option value="no">No</option>
            <option value="unsure">Not sure</option>
          </select>
        </div>

        <div class="form-field">
          <label for="message">How can we help?</label>
          <textarea id="message" name="Message" placeholder="Tell us anything that helps us prepare for you."></textarea>
        </div>

        <div class="form-field">
          <label for="appt-file">Attach a file <span class="muted" style="font-weight:400">(optional)</span></label>
          <input id="appt-file" name="attachment" type="file" accept="image/*,application/pdf,.doc,.docx" multiple />
          <p class="muted" style="font-size:.82rem;margin:.3rem 0 0">
            Optional — e.g. a photo of your lab results, referral, medication list or PhilHealth MDR (JPG, PNG or PDF).
          </p>
        </div>

        <label class="consent">
          <input type="checkbox" name="Consent (Data Privacy Act)" required />
          <span>I agree that St. John Biocare may contact me about my inquiry and handle my
          information in line with the Data Privacy Act of 2012 (RA&nbsp;10173).</span>
        </label>

        <div style="margin-top:18px">
          <button type="submit" class="btn btn--crimson">Send my request</button>
        </div>
        <p class="muted" style="font-size:.82rem;margin-top:14px">
          This form is not for emergencies. For urgent concerns, call your nearest center or the hospital ER.
        </p>
      </form>
    </div>
  </section>

  <script is:inline>
    (function () {
      var sel = document.getElementById('branch');
      var key = document.getElementById('appt-access-key');
      if (!sel || !key) return;
      function sync() {
        var opt = sel.options[sel.selectedIndex];
        var k = opt && opt.getAttribute('data-key');
        key.value = k || key.getAttribute('data-default');
      }
      sel.addEventListener('change', sync);
      sync();
    })();
  </script>

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  })} />
</BaseLayout>

<style>
  .faq { background: var(--white); border: 1px solid var(--border); border-radius: var(--radius); padding: 4px 22px; box-shadow: var(--shadow); }
  .faq summary { cursor: pointer; font-weight: 700; color: var(--forest); font-family: var(--font-head); font-size: 1.1rem; padding: 16px 0; list-style: none; display: flex; justify-content: space-between; gap: 12px; }
  .faq summary::-webkit-details-marker { display: none; }
  .faq summary::after { content: '+'; color: var(--life); font-weight: 700; font-size: 1.4rem; line-height: 1; }
  .faq[open] summary::after { content: '\2212'; }
  .faq__a { padding: 0 0 18px; color: var(--ink-soft); }
</style>
