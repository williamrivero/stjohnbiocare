---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Patient Rights & Responsibilities" description="The rights and responsibilities of every client-patient at St. John Biocare.">
  <article class="section">
    <div class="container" style="max-width:720px">
      <h1>Patient Rights &amp; Responsibilities</h1>
      <p class="lead">Every client-patient deserves respect, safety, and clear information.</p>
      <div class="notice">Draft outline — to be finalised with your clinical and compliance team.</div>
      <h2>Your rights</h2>
      <ul style="line-height:1.9">
        <li>To be treated with dignity and respect.</li>
        <li>To clear information about your care and its costs.</li>
        <li>To privacy and confidentiality of your health information.</li>
        <li>To ask questions and take part in decisions about your treatment.</li>
      </ul>
      <h2>Your responsibilities</h2>
      <ul style="line-height:1.9">
        <li>To share accurate health information.</li>
        <li>To follow the agreed care plan and schedule where you can.</li>
        <li>To treat staff and other patients with courtesy.</li>
      </ul>
    </div>
  </article>
</BaseLayout>
